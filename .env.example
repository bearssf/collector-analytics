# Required. MySQL 8+ (InnoDB). Copy to .env locally; on Render, set these in the dashboard (do not commit secrets).
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=your-database
DB_USER=your-mysql-user
DB_PASSWORD=your-password

# Strong random string in production (Render can generate one).
SESSION_SECRET=your-session-secret

# Optional
PORT=3000
# Set to production on Render so session cookies are marked Secure.
NODE_ENV=development

# Dev only: treat session as paid (unlocks The Foundry for UI testing). Never set true in production.
# DEV_SUBSCRIPTION_PAID=true

# Stripe (optional — required for billing and webhooks)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...   # must start with pk_ (not sk_). On-site /billing/subscribe; if unset: hosted Checkout
# Also accepted: NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY, VITE_STRIPE_PUBLISHABLE_KEY, STRIPE_PUBLIC_KEY
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID=price_...
# Or monthly + yearly (two buttons on Account):
# STRIPE_PRICE_MONTHLY=price_...
# STRIPE_PRICE_YEARLY=price_...
# PUBLIC_BASE_URL=https://your-service.onrender.com

# Redis (optional — recommended on Render for durable sessions across deploys / multiple instances)
# REDIS_URL=redis://... or rediss://... from your host’s Redis add-on

# The Anvil: idle delay (ms) after typing stops before the first Bedrock review; character
# edits after the first review before another review (applies reset the counter; Apply does not re-call Bedrock).
# ANVIL_INITIAL_IDLE_MS=1800
# ANVIL_INCREMENTAL_CHARS=40
# Legacy aliases (still supported): ANVIL2_INITIAL_IDLE_MS, ANVIL2_INCREMENTAL_CHARS

# Anvil: when the section draft is saved, bump revision and remove open suggestions that
# no longer match the text. Applied/ignored rows are kept. On by default; set to 0/false to disable.
# ANVIL_DRAFT_STALE_FEEDBACK=0

# AWS Bedrock (optional — Phase 7 Anvil AI review; see docs/aws-bedrock.md)
# AWS_REGION must match the Bedrock region you use (often the region inside the inference profile ARN, e.g. us-east-2)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# Inference profile (ARN or profile id — not the raw foundation model id):
# BEDROCK_INFERENCE_PROFILE_ARN=arn:aws:bedrock:us-east-2:123456789012:inference-profile/...
# Optional: profile id only (if not using _ARN)
# BEDROCK_INFERENCE_PROFILE_ID=us.anthropic.claude-...
# Or foundation model id when not using a profile:
# BEDROCK_MODEL_ID=us.anthropic.claude-3-5-sonnet-...
# Optional: Bedrock-scoped API key (if created in console — not the same as IAM access keys)
# BEDROCK_API_KEY_ID=bedrock-api-key-...
# BEDROCK_API_KEY_VALUE=...

# Semantic Scholar API key (recommended — required for reliable paper search in The Crucible).
# Request a free key at: https://www.semanticscholar.org/product/api#api-key-form
# Either name works; S2_API_KEY is checked first.
# S2_API_KEY=
# SEMANTIC_SCHOLAR_API_KEY=

# Admin-only project template editor (not linked in the app). Min 8 chars after trim (prefer longer); must match URL exactly.
# Open (recommended — works if the secret contains "/"): https://YOUR_HOST/admin/project-templates?token=YOUR_VALUE
# Legacy: https://YOUR_HOST/admin/project-templates/<TOKEN> only if TOKEN has no "/" in it.
# ADMIN_TEMPLATE_EDITOR_TOKEN=
