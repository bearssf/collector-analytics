# Required. Copy to .env locally; on Render, set these in the dashboard (do not commit secrets).
DB_HOST=your-server.database.windows.net
DB_PORT=1433
DB_NAME=your-database
DB_USER=your-user
DB_PASSWORD=your-password

# Strong random string in production (Render can generate one).
SESSION_SECRET=your-session-secret

# Optional
PORT=3000
# Set to production on Render so session cookies are marked Secure.
NODE_ENV=development
