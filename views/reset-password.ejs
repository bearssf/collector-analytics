<!DOCTYPE html>
<html lang="<%= typeof htmlLang !== 'undefined' ? htmlLang : 'en' %>" dir="<%= typeof textDir !== 'undefined' ? textDir : 'ltr' %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= t('resetPassword.pageTitle') %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/academiq.css" />
</head>
<body class="home-page">
  <div class="shell">
    <%- include('partials/topnav', { user: typeof user !== 'undefined' ? user : null, navActive: '' }) %>
    <div class="auth-page-shell">
      <div class="auth-page-card">
        <h1><%= t('resetPassword.h1') %></h1>
        <% if (typeof invalid !== 'undefined' && invalid) { %>
          <p class="error-msg">
            <% if (typeof error !== 'undefined' && error === 'expired') { %>
              <%= t('resetPassword.invalidExpired') %>
            <% } else { %>
              <%= t('resetPassword.invalidNoToken') %>
            <% } %>
          </p>
          <p><a href="/forgot-password"><%= t('resetPassword.requestNewLink') %></a></p>
        <% } else { %>
          <% if (typeof error !== 'undefined' && error === 'mismatch') { %>
            <p class="error-msg"><%= t('resetPassword.errorMismatch') %></p>
          <% } else if (typeof error !== 'undefined' && error === 'invalid') { %>
            <p class="error-msg"><%= typeof message !== 'undefined' && message ? message : t('resetPassword.errorInvalidDefault') %></p>
          <% } else if (typeof error !== 'undefined' && error === 'server') { %>
            <p class="error-msg"><%= t('resetPassword.errorServer') %></p>
          <% } %>
          <form action="/reset-password" method="post">
            <input type="hidden" name="token" value="<%= typeof token !== 'undefined' ? token : '' %>" />
            <div class="field">
              <label for="rp-password"><%= t('resetPassword.newPassword') %></label>
              <input type="password" id="rp-password" name="password" required minlength="8" autocomplete="new-password" />
            </div>
            <div class="field">
              <label for="rp-password2"><%= t('resetPassword.confirmNewPassword') %></label>
              <input type="password" id="rp-password2" name="passwordConfirm" required minlength="8" autocomplete="new-password" />
            </div>
            <div class="btn-row">
              <button type="submit" class="btn btn-blue"><%= t('resetPassword.submit') %></button>
              <a href="/"><%= t('resetPassword.cancel') %></a>
            </div>
          </form>
        <% } %>
      </div>
    </div>
  </div>
</body>
</html>
