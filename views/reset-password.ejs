<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Set new password – AcademiqForge</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/academiq.css" />
</head>
<body class="home-page">
  <div class="shell">
    <%- include('partials/topnav', { user: typeof user !== 'undefined' ? user : null, navActive: '' }) %>
    <div class="auth-page-shell">
      <div class="auth-page-card">
        <h1>Set a new password</h1>
        <% if (typeof invalid !== 'undefined' && invalid) { %>
          <p class="error-msg">
            <% if (typeof error !== 'undefined' && error === 'expired') { %>
              This reset link is invalid or has expired.
            <% } else { %>
              No reset token was provided or the link is invalid.
            <% } %>
          </p>
          <p><a href="/forgot-password">Request a new reset link</a></p>
        <% } else { %>
          <% if (typeof error !== 'undefined' && error === 'mismatch') { %>
            <p class="error-msg">Passwords do not match.</p>
          <% } else if (typeof error !== 'undefined' && error === 'invalid') { %>
            <p class="error-msg"><%= typeof message !== 'undefined' && message ? message : 'This link is invalid or expired.' %></p>
          <% } else if (typeof error !== 'undefined' && error === 'server') { %>
            <p class="error-msg">Something went wrong. Try again.</p>
          <% } %>
          <form action="/reset-password" method="post">
            <input type="hidden" name="token" value="<%= typeof token !== 'undefined' ? token : '' %>" />
            <div class="field">
              <label for="rp-password">New password</label>
              <input type="password" id="rp-password" name="password" required minlength="8" autocomplete="new-password" />
            </div>
            <div class="field">
              <label for="rp-password2">Confirm new password</label>
              <input type="password" id="rp-password2" name="passwordConfirm" required minlength="8" autocomplete="new-password" />
            </div>
            <div class="btn-row">
              <button type="submit" class="btn btn-blue">Update password</button>
              <a href="/">Cancel</a>
            </div>
          </form>
        <% } %>
      </div>
    </div>
  </div>
</body>
</html>
