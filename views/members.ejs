<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Members – CollectorAnalytics</title>
  <style>
    * { box-sizing: border-box; }
    body {
      margin: 0;
      min-height: 100vh;
      background: #000;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
      color: #fff;
      padding: 2rem;
    }
    .header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 2rem;
    }
    .header a { color: #f0c674; text-decoration: none; }
    .header a:hover { text-decoration: underline; }
    h1 { margin: 0 0 1rem; font-size: 1.75rem; }
    .card {
      background: #111;
      border: 1px solid #333;
      border-radius: 12px;
      padding: 2rem;
      max-width: 600px;
    }
    .card p { color: #ccc; margin: 0; }
  </style>
</head>
<body>
  <div class="header">
    <a href="/">← Home</a>
    <span>Welcome, <%= user.firstName %></span>
  </div>

  <h1>Members only</h1>
  <div class="card">
    <p>This area is for paying members. You're subscribed<%= user.subscription && user.subscription.plan === 'yearly' ? ' (yearly)' : ' (monthly)' %>. More member content can go here.</p>
  </div>
</body>
</html>
