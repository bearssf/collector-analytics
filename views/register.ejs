<!DOCTYPE html>
<html lang="<%= typeof htmlLang !== 'undefined' ? htmlLang : 'en' %>" dir="<%= typeof textDir !== 'undefined' ? textDir : 'ltr' %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= t('register.pageTitle') %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #0a0a0a;
      --card: #121212;
      --border: rgba(255, 255, 255, 0.08);
      --text: #f5f5f5;
      --muted: #9ca3af;
      --primary: #2b82f6;
      --primary-hover: #4b93f7;
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      min-height: 100vh;
      background-color: var(--bg);
      background-image:
        radial-gradient(ellipse 70% 50% at 20% 20%, rgba(43, 130, 246, 0.1) 0%, transparent 50%),
        radial-gradient(ellipse 50% 40% at 85% 75%, rgba(43, 130, 246, 0.06) 0%, transparent 45%);
      color: var(--text);
      font-family: Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      font-size: 15px;
      line-height: 1.5;
      padding: 0 1.25rem 3rem;
    }
    a { color: inherit; }

    .shell {
      max-width: 520px;
      margin: 0 auto;
    }

    .topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.25rem 0 1.5rem;
    }
    .brand {
      display: flex;
      align-items: center;
      gap: 0.65rem;
      text-decoration: none;
    }
    .brand-mark {
      width: 36px;
      height: 36px;
      border-radius: 8px;
      background: #141414;
      border: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .brand-mark span {
      width: 14px;
      height: 14px;
      border-radius: 50%;
      background: var(--primary);
      box-shadow: 0 0 12px rgba(43, 130, 246, 0.5);
    }
    .brand-name {
      font-weight: 600;
      font-size: 1rem;
      letter-spacing: -0.02em;
      color: #fff;
    }
    .topbar-link {
      font-size: 0.875rem;
      font-weight: 500;
      color: var(--muted);
      text-decoration: none;
    }
    .topbar-link:hover { color: #e5e7eb; }

    .card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 2rem;
    }
    h1 {
      font-family: 'Libre Baskerville', Georgia, serif;
      margin: 0 0 1.25rem;
      font-size: 1.5rem;
      font-weight: 400;
      color: #fafafa;
    }
    .form-group {
      margin-bottom: 1rem;
    }
    .form-group label {
      display: block;
      margin-bottom: 0.35rem;
      font-size: 0.8rem;
      font-weight: 500;
      color: var(--muted);
    }
    .form-group label .opt {
      color: #6b7280;
      font-weight: 400;
    }
    .form-group input,
    .form-group select,
    .form-group textarea {
      width: 100%;
      padding: 0.6rem 0.75rem;
      border: 1px solid rgba(255, 255, 255, 0.12);
      border-radius: 8px;
      background: #0a0a0a;
      color: #fff;
      font-size: 0.95rem;
      font-family: inherit;
    }
    .form-group input:focus,
    .form-group select:focus,
    .form-group textarea:focus {
      outline: none;
      border-color: var(--primary);
    }
    .form-group textarea {
      min-height: 4.5rem;
      resize: vertical;
    }
    .form-group input::placeholder { color: #6b7280; }
    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.75rem;
    }
    @media (max-width: 520px) {
      .form-row { grid-template-columns: 1fr; }
    }
    .error {
      color: #f87171;
      font-size: 0.9rem;
      margin-bottom: 1rem;
    }
    button[type="submit"] {
      width: 100%;
      padding: 0.7rem 1rem;
      background: var(--primary);
      color: #fff;
      border: none;
      border-radius: 8px;
      font-size: 1rem;
      font-weight: 600;
      cursor: pointer;
      margin-top: 0.5rem;
      font-family: inherit;
      transition: background 0.15s;
    }
    button[type="submit"]:hover { background: var(--primary-hover); }
    .back {
      display: inline-block;
      margin-top: 1.5rem;
      color: var(--primary);
      font-size: 0.9rem;
      text-decoration: none;
      font-weight: 500;
    }
    .back:hover { text-decoration: underline; }
    .hint {
      font-size: 0.75rem;
      color: #6b7280;
      margin-top: 0.35rem;
    }
    .register-membership {
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 10px;
      padding: 1rem 1.1rem 1.15rem;
      margin: 1.25rem 0 0.5rem;
    }
    .register-membership legend {
      padding: 0 0.35rem;
      font-size: 0.85rem;
      font-weight: 600;
      color: #e5e7eb;
    }
    .register-membership-lead {
      margin: 0 0 0.85rem;
      font-size: 0.82rem;
      color: var(--muted);
      line-height: 1.45;
    }
    .register-radio {
      display: flex;
      align-items: flex-start;
      gap: 0.5rem;
      margin-bottom: 0.65rem;
      font-size: 0.9rem;
      line-height: 1.4;
      cursor: pointer;
      color: #e5e7eb;
    }
    .register-radio input {
      margin-top: 0.2rem;
      width: auto;
      flex-shrink: 0;
    }
    .register-interval {
      margin: 0.75rem 0 0.5rem 1.5rem;
      padding: 0.65rem 0.75rem;
      border-radius: 8px;
      background: rgba(0, 0, 0, 0.25);
      display: none;
    }
    .register-interval.register-interval--visible {
      display: block;
    }
    .register-interval-label {
      display: block;
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: #9ca3af;
      margin-bottom: 0.45rem;
    }
    .register-interval label {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      margin-right: 1rem;
      font-size: 0.88rem;
      cursor: pointer;
    }
    .register-interval input {
      width: auto;
    }
    .register-promo-wrap {
      margin-top: 0.75rem;
    }
  </style>
</head>
<body>
  <div class="shell">
    <header class="topbar">
      <a href="/" class="brand" title="Home">
        <div class="brand-mark" aria-hidden="true"><span></span></div>
        <span class="brand-name">AcademiqForge</span>
      </a>
      <a href="/" class="topbar-link"><%= t('register.topLinkHome') %></a>
    </header>

    <div class="card">
      <h1><%= t('register.title') %></h1>
      <% if (error) { %><p class="error"><%= error %></p><% } %>
      <form action="/register" method="post" autocomplete="off" id="reg-form">
        <div class="form-group">
          <label for="title"><%= t('register.titleLabel') %><%= t('register.requiredStar') %></label>
          <select id="title" name="title" required>
            <option value="" disabled <%= !form.title ? 'selected' : '' %>><%= t('project.select') %></option>
            <% (typeof allowedTitles !== 'undefined' ? allowedTitles : ['mr', 'mrs', 'ms', 'miss', 'mx', 'dr']).forEach(function (tk) { %>
              <option value="<%= tk %>" <%= form.title === tk ? 'selected' : '' %>><%= t('accountTitles.' + tk) %></option>
            <% }); %>
          </select>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label for="firstName"><%= t('register.firstName') %><%= t('register.requiredStar') %></label>
            <input type="text" id="firstName" name="firstName" required placeholder="<%= t('register.firstNamePlaceholder') %>" value="<%= form.firstName || '' %>" />
          </div>
          <div class="form-group">
            <label for="lastName"><%= t('register.lastName') %><%= t('register.requiredStar') %></label>
            <input type="text" id="lastName" name="lastName" required placeholder="<%= t('register.lastNamePlaceholder') %>" value="<%= form.lastName || '' %>" />
          </div>
        </div>
        <div class="form-group">
          <label for="email"><%= t('auth.email') %><%= t('register.requiredStar') %></label>
          <input type="email" id="email" name="email" required placeholder="<%= t('register.emailPlaceholder') %>" value="<%= form.email || '' %>" autocomplete="email" />
        </div>
        <div class="form-group">
          <label for="password"><%= t('auth.password') %><%= t('register.requiredStar') %></label>
          <input type="password" id="password" name="password" required placeholder="<%= t('register.passwordPlaceholder') %>" minlength="8" autocomplete="new-password" />
        </div>
        <div class="form-group">
          <label for="passwordConfirm"><%= t('register.confirmPassword') %><%= t('register.requiredStar') %></label>
          <input type="password" id="passwordConfirm" name="passwordConfirm" required placeholder="<%= t('register.confirmPasswordPlaceholder') %>" minlength="8" autocomplete="new-password" />
        </div>

        <div class="form-group">
          <label for="university"><%= t('register.university') %> <span class="opt"><%= t('register.optionalInParens') %></span></label>
          <input type="text" id="university" name="university" list="university-list" placeholder="<%= t('register.universityPlaceholder') %>" value="<%= form.university || '' %>" />
          <datalist id="university-list">
            <% universities.forEach(function (u) { %>
              <option value="<%= u %>"></option>
            <% }); %>
          </datalist>
          <p class="hint"><%= t('register.universityHint') %></p>
        </div>
        <div class="form-group">
          <label for="researchFocus"><%= t('register.researchFocus') %> <span class="opt"><%= t('register.optionalInParens') %></span></label>
          <textarea id="researchFocus" name="researchFocus" placeholder="<%= t('register.researchFocusPlaceholder') %>"><%= form.researchFocus || '' %></textarea>
        </div>
        <div class="form-group">
          <label for="preferredSearchEngine"><%= t('register.preferredSearchEngine') %> <span class="opt"><%= t('register.optionalInParens') %></span></label>
          <select id="preferredSearchEngine" name="preferredSearchEngine">
            <option value="">—</option>
            <% searchEngines.forEach(function (sk) { %>
              <option value="<%= sk %>" <%= form.preferredSearchEngine === sk ? 'selected' : '' %>><%= t('searchEngineOptions.' + sk) %></option>
            <% }); %>
          </select>
        </div>

        <% if (typeof memberSubscribeAvailable !== 'undefined' && memberSubscribeAvailable) { %>
        <fieldset class="register-membership">
          <legend><%= t('register.membershipLegend') %></legend>
          <p class="register-membership-lead">
            <%= t('register.membershipLead') %>
          </p>
          <label class="register-radio">
            <input type="radio" name="subscribeChoice" value="free" <%= (form.subscribeChoice || 'free') !== 'member' ? 'checked' : '' %> />
            <span><%= t('register.subscribeFree') %></span>
          </label>
          <label class="register-radio">
            <input type="radio" name="subscribeChoice" value="member" <%= form.subscribeChoice === 'member' ? 'checked' : '' %> />
            <span><%= t('register.subscribeMember') %></span>
          </label>
          <% if (typeof billingPriceMode !== 'undefined' && billingPriceMode === 'dual') { %>
          <div class="register-interval" id="register-interval" aria-live="polite">
            <span class="register-interval-label"><%= t('register.planLabel') %></span>
            <label>
              <input type="radio" name="billingInterval" value="month" <%= (form.billingInterval || 'month') !== 'year' ? 'checked' : '' %> />
              <%= t('billing.intervalMonthly') %>
            </label>
            <label>
              <input type="radio" name="billingInterval" value="year" <%= form.billingInterval === 'year' ? 'checked' : '' %> />
              <%= t('billing.intervalYearly') %>
            </label>
          </div>
          <% } %>
          <div class="form-group register-promo-wrap" id="register-promo-wrap">
            <label for="subscribePromo"><%= t('register.promoLabel') %> <span class="opt"><%= t('register.optionalInParens') %></span></label>
            <input type="text" id="subscribePromo" name="subscribePromo" placeholder="<%= t('register.promoPlaceholder') %>" value="<%= form.subscribePromo || '' %>" autocomplete="off" />
          </div>
        </fieldset>
        <% } %>

        <button type="submit"><%= t('register.submit') %></button>
      </form>
    </div>
    <a href="/" class="back"><%= t('register.backToHome') %></a>
  </div>
  <% var _regAlert = JSON.stringify({ alertPasswordMismatch: t('register.alertPasswordMismatch') }).replace(/</g, '\\u003c'); %>
  <script type="application/json" id="register-i18n"><%- _regAlert %></script>
  <script>
    (function () {
      var i18n = { alertPasswordMismatch: 'Password and confirmation must match.' };
      var el = document.getElementById('register-i18n');
      if (el && el.textContent) {
        try { i18n = Object.assign(i18n, JSON.parse(el.textContent)); } catch (e) {}
      }
      var form = document.getElementById('reg-form');
      var p1 = document.getElementById('password');
      var p2 = document.getElementById('passwordConfirm');
      form.addEventListener('submit', function (e) {
        if (p1.value !== p2.value) {
          e.preventDefault();
          alert(i18n.alertPasswordMismatch);
        }
      });

      var intervalEl = document.getElementById('register-interval');
      var promoWrap = document.getElementById('register-promo-wrap');
      function syncMembershipUi() {
        var member = document.querySelector('input[name="subscribeChoice"][value="member"]');
        var show = member && member.checked;
        if (intervalEl) {
          intervalEl.classList.toggle('register-interval--visible', !!show);
        }
        if (promoWrap) {
          promoWrap.style.display = show ? '' : 'none';
        }
      }
      document.querySelectorAll('input[name="subscribeChoice"]').forEach(function (r) {
        r.addEventListener('change', syncMembershipUi);
      });
      syncMembershipUi();
    })();
  </script>
</body>
</html>
