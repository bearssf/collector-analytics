<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Create account – AcademiqForge</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
  <style>
    * { box-sizing: border-box; }
    body {
      margin: 0;
      min-height: 100vh;
      background: #000;
      font-family: 'Libre Baskerville', Georgia, serif;
      color: #fff;
      padding: 2rem 1rem 3rem;
    }
    .wrap {
      max-width: 480px;
      margin: 0 auto;
    }
    .card {
      background: #0d0d0d;
      border: 1px solid #2a2a2a;
      border-radius: 12px;
      padding: 2rem;
    }
    h1 {
      margin: 0 0 1.25rem;
      font-size: 1.4rem;
      font-weight: 400;
      color: #e8e8e8;
    }
    .form-group {
      margin-bottom: 1rem;
    }
    .form-group label {
      display: block;
      margin-bottom: 0.35rem;
      font-size: 0.85rem;
      color: #b0b0b0;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    }
    .form-group label .opt {
      color: #666;
      font-weight: 400;
    }
    .form-group input,
    .form-group select,
    .form-group textarea {
      width: 100%;
      padding: 0.55rem 0.7rem;
      border: 1px solid #3a3a3a;
      border-radius: 6px;
      background: #161616;
      color: #fff;
      font-size: 0.95rem;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    }
    .form-group textarea {
      min-height: 4.5rem;
      resize: vertical;
    }
    .form-group input::placeholder { color: #666; }
    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.75rem;
    }
    @media (max-width: 520px) {
      .form-row { grid-template-columns: 1fr; }
    }
    .error {
      color: #e07a7a;
      font-size: 0.9rem;
      margin-bottom: 1rem;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    }
    button[type="submit"] {
      width: 100%;
      padding: 0.75rem;
      background: #1a6cad;
      color: #fff;
      border: none;
      border-radius: 6px;
      font-size: 1rem;
      cursor: pointer;
      margin-top: 0.5rem;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    }
    button[type="submit"]:hover { background: #3584e4; }
    .back {
      display: inline-block;
      margin-top: 1.25rem;
      color: #56b4e9;
      font-size: 0.9rem;
      text-decoration: none;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    }
    .back:hover { text-decoration: underline; }
    .hint {
      font-size: 0.75rem;
      color: #666;
      margin-top: 0.35rem;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="card">
      <h1>Create account</h1>
      <% if (error) { %><p class="error"><%= error %></p><% } %>
      <form action="/register" method="post" autocomplete="off" id="reg-form">
        <div class="form-group">
          <label for="title">Title *</label>
          <select id="title" name="title" required>
            <option value="" disabled <%= !form.title ? 'selected' : '' %>>Select…</option>
            <% ['Mr.', 'Mrs.', 'Ms.', 'Miss', 'Mx.', 'Dr.'].forEach(function (t) { %>
              <option value="<%= t %>" <%= form.title === t ? 'selected' : '' %>><%= t %></option>
            <% }); %>
          </select>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label for="firstName">First name *</label>
            <input type="text" id="firstName" name="firstName" required placeholder="First name" value="<%= form.firstName || '' %>" />
          </div>
          <div class="form-group">
            <label for="lastName">Last name *</label>
            <input type="text" id="lastName" name="lastName" required placeholder="Last name" value="<%= form.lastName || '' %>" />
          </div>
        </div>
        <div class="form-group">
          <label for="email">Email *</label>
          <input type="email" id="email" name="email" required placeholder="you@university.edu" value="<%= form.email || '' %>" autocomplete="email" />
        </div>
        <div class="form-group">
          <label for="password">Password *</label>
          <input type="password" id="password" name="password" required placeholder="At least 8 characters" minlength="8" autocomplete="new-password" />
        </div>
        <div class="form-group">
          <label for="passwordConfirm">Confirm password *</label>
          <input type="password" id="passwordConfirm" name="passwordConfirm" required placeholder="Re-enter password" minlength="8" autocomplete="new-password" />
        </div>

        <div class="form-group">
          <label for="university">University <span class="opt">(optional)</span></label>
          <input type="text" id="university" name="university" list="university-list" placeholder="Type or choose from list" value="<%= form.university || '' %>" />
          <datalist id="university-list">
            <% universities.forEach(function (u) { %>
              <option value="<%= u %>"></option>
            <% }); %>
          </datalist>
          <p class="hint">Pick a school from suggestions or type your institution if it isn’t listed.</p>
        </div>
        <div class="form-group">
          <label for="researchFocus">Research focus <span class="opt">(optional)</span></label>
          <textarea id="researchFocus" name="researchFocus" placeholder="e.g. computational linguistics"><%= form.researchFocus || '' %></textarea>
        </div>
        <div class="form-group">
          <label for="preferredSearchEngine">Preferred search engine <span class="opt">(optional)</span></label>
          <select id="preferredSearchEngine" name="preferredSearchEngine">
            <option value="">—</option>
            <% searchEngines.forEach(function (se) { %>
              <option value="<%= se %>" <%= form.preferredSearchEngine === se ? 'selected' : '' %>><%= se %></option>
            <% }); %>
          </select>
        </div>

        <button type="submit">Create account</button>
      </form>
    </div>
    <a href="/" class="back">← Back to home</a>
  </div>
  <script>
    (function () {
      var form = document.getElementById('reg-form');
      var p1 = document.getElementById('password');
      var p2 = document.getElementById('passwordConfirm');
      form.addEventListener('submit', function (e) {
        if (p1.value !== p2.value) {
          e.preventDefault();
          alert('Password and confirmation must match.');
        }
      });
    })();
  </script>
</body>
</html>
