<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Product – AcademiqForge</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/academiq.css" />
</head>
<body>
  <%
    const features = [
      { name: "The Anvil", desc: "Write in a focused workspace with argument guidance, clarity feedback, and completion momentum." },
      { name: "The Archive", desc: "Capture, organize, and connect sources so your evidence is always within reach." },
      { name: "The Lattice", desc: "Map sources to claims and strengthen the logical structure of your paper." },
    ];
    const steps = ["Capture your research", "Build your structure", "Strengthen your arguments", "Finish your paper"];
    const navItems = ["Dashboard", "The Anvil", "The Archive", "The Lattice"];
    const insightItems = ["Clarify design choice", "Tighten participant logic", "Resolve APA issues"];
  %>
  <div class="shell">
    <%- include('partials/topnav', { user: user, navActive: navActive || 'product' }) %>

    <section class="section product" id="product">
      <div>
        <div class="eyebrow">A focused product experience</div>
        <h2>Calm enough for deep work. Smart enough to move you forward.</h2>
        <p class="sub">AcademiqForge combines writing, source organization, argument feedback, and structural guidance in one restrained workspace.</p>
      </div>
      <div class="product-panel">
        <div class="triple">
          <div class="box">
            <div class="u">Navigation</div>
            <div class="nav-list">
              <% navItems.forEach(function (item, index) { %>
                <div class="<%= index === 1 ? 'active' : '' %>"><%= item %></div>
              <% }) %>
            </div>
          </div>
          <div class="box">
            <div class="row">
              <div><div class="u">Workspace</div><div class="workspace-title">Methodology</div></div>
              <div style="font-size:.84rem;color:rgba(255,255,255,.47)">1,284 words</div>
            </div>
            <div class="copy" style="margin-top:.7rem">
              <p>This study employed a qualitative multiple-case design to explore how critical thinking and relationship-development factors interact during early-stage intercultural business relationships.</p>
              <p>Data collection included semi-structured interviews, researcher memos, and document review to support triangulation and contextual depth.</p>
              <div class="hint">Consider adding one sentence clarifying why multiple-case design is stronger than a single-case alternative.</div>
            </div>
          </div>
          <div class="box">
            <div class="u">Insights</div>
            <div class="ins">
              <% insightItems.forEach(function (item) { %>
                <div class="ins-item"><%= item %></div>
              <% }) %>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="workflow" id="workflow">
      <div class="workflow-top">
        <div><div class="eyebrow">How it works</div><h2>A system designed to keep research moving.</h2></div>
        <p class="sub">Bring research into one place, shape it into structure, strengthen the logic, and keep progressing toward a finished paper.</p>
      </div>
      <div class="steps">
        <% steps.forEach(function (step, i) { %>
          <div class="step"><div class="n">0<%= i + 1 %></div><div class="t"><%= step %></div></div>
        <% }) %>
      </div>
    </section>

    <section class="section" id="features">
      <div style="max-width:820px">
        <div class="eyebrow">The forge system</div>
        <h2>Three connected environments, one research flow.</h2>
      </div>
      <div class="feature-grid" style="margin-top:1.4rem">
        <% features.forEach(function (feature) { %>
          <article class="card">
            <div style="display:flex; align-items:flex-start; justify-content:space-between; gap:1rem;">
              <div><h3 style="font-size:2rem"><%= feature.name %></h3><p><%= feature.desc %></p></div>
              <div class="ico" style="margin-bottom:0"></div>
            </div>
          </article>
        <% }) %>
      </div>
    </section>

    <section class="cta" id="cta">
      <div class="cta-glow"></div>
      <div class="cta-inner">
        <div class="eyebrow">Ready to begin</div>
        <h2>Build with more clarity. Finish with more confidence.</h2>
        <p class="sub">Start with a focused writing environment and grow into the full research operating system.</p>
        <div class="hero-actions" style="justify-content:center; margin-top:1.5rem;">
          <button type="button" class="btn btn-blue">Start Forging</button>
          <button type="button" class="btn btn-outline">Schedule a Demo</button>
        </div>
      </div>
    </section>
  </div>

  <%- include('partials/signin-modal', { user: user, error: error, returnTo: typeof returnTo !== 'undefined' ? returnTo : '/product', openSignin: typeof openSignin !== 'undefined' && openSignin, resetSuccess: typeof resetSuccess !== 'undefined' && resetSuccess }) %>
</body>
</html>
