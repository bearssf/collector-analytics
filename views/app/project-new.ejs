<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/app-head', { title: 'Forge a new project' }) %>
</head>
<body class="app-body">
  <div class="app-grid">
    <%- include('../partials/app-sidebar', { user: user, navActive: 'dashboard', projects: projects, currentProjectId: currentProjectId, workspaceSlug: '', appAccess: appAccess }) %>
    <main class="app-canvas">
      <h1>Forge a new project</h1>
      <p class="sub">Name your work, pick a purpose and citation style, and choose a section template.</p>

      <% if (error) { %>
        <div class="app-form-error" role="alert"><%= error %></div>
      <% } %>

      <form class="app-form-stack" method="post" action="/app/projects">
        <label class="app-field">
          <span>Project name</span>
          <input type="text" name="name" required maxlength="255" value="<%= form.name || '' %>" placeholder="e.g. Dissertation chapter 3" autocomplete="off" />
        </label>
        <label class="app-field">
          <span>Purpose</span>
          <select name="purpose" required>
            <option value="" disabled <%= !form.purpose ? 'selected' : '' %>>Select…</option>
            <% purposes.forEach(function(p) { %>
              <option value="<%= p %>" <%= form.purpose === p ? 'selected' : '' %>><%= p %></option>
            <% }); %>
          </select>
        </label>
        <label class="app-field">
          <span>Citation style</span>
          <select name="citationStyle" required>
            <option value="" disabled <%= !form.citationStyle ? 'selected' : '' %>>Select…</option>
            <% citationStyles.forEach(function(c) { %>
              <option value="<%= c %>" <%= form.citationStyle === c ? 'selected' : '' %>><%= c %></option>
            <% }); %>
          </select>
        </label>
        <label class="app-field">
          <span>Template</span>
          <select name="templateKey" required>
            <option value="" disabled <%= !form.templateKey ? 'selected' : '' %>>Select…</option>
            <% templateOptions.forEach(function(t) { %>
              <option value="<%= t.key %>" <%= form.templateKey === t.key ? 'selected' : '' %>><%= t.label %></option>
            <% }); %>
          </select>
        </label>
        <div class="app-form-actions">
          <button type="submit" class="app-btn-primary">Create project</button>
          <a href="/app/dashboard" class="app-link-muted">Cancel</a>
        </div>
      </form>
    </main>
    <%- include('../partials/app-insight-panel', { insightHint: 'After creation you land in The Anvil for this project.' }) %>
  </div>
</body>
</html>
