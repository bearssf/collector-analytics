<!DOCTYPE html>
<html lang="<%= typeof htmlLang !== 'undefined' ? htmlLang : 'en' %>" dir="<%= typeof textDir !== 'undefined' ? textDir : 'ltr' %>">
<head>
  <!-- billing: <%= typeof stripeElementsConfigured !== 'undefined' && stripeElementsConfigured ? 'subscribe-on-site' : 'checkout-redirect' %> -->
  <!-- deploy: git <%= process.env.RENDER_GIT_COMMIT || 'unknown' %> -->
  <% var title = t('account.title'); %>
  <%- include('../partials/app-head') %>
</head>
<body class="app-body app-body--account-page" data-subscription-success="<%= typeof subscriptionSuccessReturn !== 'undefined' && subscriptionSuccessReturn ? '1' : '' %>">
  <%
    var _titleSlug = { 'Mr.': 'mr', 'Mrs.': 'mrs', 'Ms.': 'ms', 'Miss': 'miss', 'Mx.': 'mx', 'Dr.': 'dr' };
    function formatTitleOption(tv) {
      var slug = _titleSlug[tv];
      return slug ? t('accountTitles.' + slug) : tv;
    }
    var _seSlug = {
      'Google Scholar': 'googleScholar',
      'Worldcat.org': 'worldcat',
      'PubMed Central': 'pubMedCentral',
      'JSTOR': 'jstor',
      'CORE': 'core',
      'Semantic Scholar': 'semanticScholar',
      'ResearchGate': 'researchGate',
      'Lens.org': 'lens',
      'Other/University Specific': 'otherUniversity'
    };
    function formatSearchEngineLabel(s) {
      var k = _seSlug[s];
      return k ? t('searchEngineOptions.' + k) : s;
    }
  %>
  <div class="app-grid app-grid--account">
    <%- include('../partials/app-sidebar', { user: user, navActive: 'account', projects: projects, currentProjectId: currentProjectId, workspaceSlug: '', appAccess: appAccess }) %>
    <main class="app-canvas">
      <h1><%= t('account.title') %></h1>
      <p class="sub"><%= t('account.sub') %></p>

      <% if (typeof billingFlash !== 'undefined' && billingFlash) { %>
        <div class="account-flash account-flash--<%= billingFlash.kind %>"><%= billingFlash.text %></div>
      <% } %>
      <% if (typeof subscriptionSuccessReturn !== 'undefined' && subscriptionSuccessReturn && !appAccess.paid) { %>
        <div id="account-billing-pending" class="account-billing-pending">
          <p class="account-billing-pending__text"><%= t('account.billingPendingLead') %> <button type="button" id="account-billing-refresh-btn" class="account-billing-pending__btn"><%= t('account.refreshStatus') %></button>.</p>
          <p id="account-billing-poll-status" class="account-meta account-billing-pending__meta" hidden><%= t('account.stillConfirming') %></p>
        </div>
      <% } %>

      <% var showSubMaintain = stripeConfigured && subscriptionRow && subscriptionRow.stripe_subscription_id && (appAccess.paid || subscriptionRow.status === 'past_due'); %>
      <% var capEnd = subscriptionRow && (subscriptionRow.cancel_at_period_end === true || subscriptionRow.cancel_at_period_end === 1); %>
      <% var showYearlyMonthlyWindowNotice = showSubMaintain && typeof billingPriceMode !== 'undefined' && billingPriceMode === 'dual' && currentPlanInterval === 'year' && typeof within30DaysOfRenewal !== 'undefined' && !within30DaysOfRenewal; %>

      <div class="app-placeholder account-block">
        <div class="account-layout">
          <div class="account-layout__profile">
            <h2 class="account-h2"><%= t('account.profileH2') %></h2>
            <p class="account-meta account-meta--profile"><%= t('account.profileMeta') %></p>
            <form id="account-profile-form" class="app-form-stack account-form" autocomplete="off">
              <% var _ploc = (profile.preferredLocale != null && profile.preferredLocale !== '') ? profile.preferredLocale : locale; %>
              <% var _titles = typeof allowedTitles !== 'undefined' && allowedTitles.length ? allowedTitles : ['Mr.', 'Mrs.', 'Ms.', 'Miss', 'Mx.', 'Dr.']; %>
              <label class="app-field">
                <span><%= t('account.labelTitle') %> <abbr class="account-required-star" title="<%= t('account.requiredAbbr') %>">*</abbr></span>
                <select name="title" required>
                  <option value="" disabled <%= !profile.title ? 'selected' : '' %>><%= t('project.select') %></option>
                  <% _titles.forEach(function (tv) { %>
                    <option value="<%= tv %>" <%= profile.title === tv ? 'selected' : '' %>><%= formatTitleOption(tv) %></option>
                  <% }); %>
                </select>
              </label>
              <label class="app-field">
                <span><%= t('account.labelFirstName') %> <abbr class="account-required-star" title="<%= t('account.requiredAbbr') %>">*</abbr></span>
                <input type="text" name="firstName" required maxlength="100" value="<%= profile.firstName || '' %>" />
              </label>
              <label class="app-field">
                <span><%= t('account.labelLastName') %> <abbr class="account-required-star" title="<%= t('account.requiredAbbr') %>">*</abbr></span>
                <input type="text" name="lastName" required maxlength="100" value="<%= profile.lastName || '' %>" />
              </label>
              <label class="app-field">
                <span><%= t('account.labelEmail') %> <abbr class="account-required-star" title="<%= t('account.requiredAbbr') %>">*</abbr></span>
                <input type="email" value="<%= profile.email || user.email %>" readonly aria-readonly="true" />
              </label>
              <label class="app-field">
                <span><%= t('account.labelUniversity') %></span>
                <input type="text" name="university" list="account-university-list" maxlength="255" placeholder="<%= t('account.placeholderUniversity') %>" value="<%= profile.university || '' %>" />
                <datalist id="account-university-list">
                  <% (typeof universities !== 'undefined' ? universities : []).forEach(function (u) { %>
                    <option value="<%= u %>"></option>
                  <% }); %>
                </datalist>
              </label>
              <label class="app-field">
                <span><%= t('account.labelResearchFocus') %></span>
                <textarea name="researchFocus" rows="3" maxlength="8000" placeholder="<%= t('account.placeholderResearchFocus') %>"><%= profile.researchFocus || '' %></textarea>
              </label>
              <label class="app-field">
                <span><%= t('account.labelPreferredSearchEngine') %></span>
                <select name="preferredSearchEngine">
                  <option value="" <%= !profile.preferredSearchEngine ? 'selected' : '' %>><%= t('project.select') %></option>
                  <% (typeof searchEngines !== 'undefined' ? searchEngines : []).forEach(function (s) { %>
                    <option value="<%= s %>" <%= profile.preferredSearchEngine === s ? 'selected' : '' %>><%= formatSearchEngineLabel(s) %></option>
                  <% }); %>
                </select>
              </label>
              <label class="app-field">
                <span><%= t('account.languageH2') %></span>
                <select name="preferredLocale" id="account-preferred-locale" aria-label="<%= t('account.languageH2') %>">
                  <% (typeof localeOptions !== 'undefined' ? localeOptions : []).forEach(function (opt) { %>
                    <option value="<%= opt.id %>" <%= String(_ploc) === String(opt.id) ? 'selected' : '' %>><%= opt.label %></option>
                  <% }); %>
                </select>
              </label>
              <p class="account-meta"><%= t('account.languageMeta') %></p>
              <div id="account-profile-msg" class="account-form-msg" role="status" aria-live="polite" hidden></div>
              <div class="app-form-actions app-form-actions--account-save">
                <button type="submit" class="app-btn-primary" id="account-profile-submit"><%= t('account.saveProfile') %></button>
              </div>
              <p class="account-form-required-note"><abbr class="account-required-star" title="<%= t('account.requiredAbbr') %>">*</abbr> <%= t('account.requiredNote') %></p>
            </form>
          </div>

          <div class="account-layout__aside">
            <section class="account-rail-section">
              <h2 class="account-h2"><%= t('account.passwordH2') %></h2>
              <p class="account-meta account-meta--password-reset"><a href="/forgot-password"><%= t('account.passwordForgot') %></a></p>
              <form id="account-password-form" class="app-form-stack account-form" autocomplete="off" novalidate>
                <label class="app-field account-password-field">
                  <span><%= t('account.currentPasswordField') %> <abbr class="account-required-star" title="<%= t('account.requiredAbbr') %>">*</abbr></span>
                  <span class="account-password-field__inner">
                    <input type="password" name="currentPassword" required autocomplete="current-password" />
                    <button type="button" class="account-password-toggle account-password-toggle--eye" data-password-toggle data-pwd-kind="current" aria-label="<%= t('auth.password') %>" aria-pressed="false" title="<%= t('client.account.showPassword') %>">
                      <%- include('../partials/password-visibility-icons') %>
                    </button>
                  </span>
                </label>
                <label class="app-field account-password-field">
                  <span><%= t('account.newPasswordField') %> <abbr class="account-required-star" title="<%= t('account.requiredAbbr') %>">*</abbr></span>
                  <span class="account-password-field__inner">
                    <input type="password" name="newPassword" required minlength="8" autocomplete="new-password" />
                    <button type="button" class="account-password-toggle account-password-toggle--eye" data-password-toggle data-pwd-kind="new" aria-label="<%= t('auth.password') %>" aria-pressed="false" title="<%= t('client.account.showPassword') %>">
                      <%- include('../partials/password-visibility-icons') %>
                    </button>
                  </span>
                </label>
                <label class="app-field account-password-field">
                  <span><%= t('account.confirmPasswordField') %> <abbr class="account-required-star" title="<%= t('account.requiredAbbr') %>">*</abbr></span>
                  <span class="account-password-field__inner">
                    <input type="password" name="confirmPassword" required minlength="8" autocomplete="new-password" />
                    <button type="button" class="account-password-toggle account-password-toggle--eye" data-password-toggle data-pwd-kind="confirm" aria-label="<%= t('auth.password') %>" aria-pressed="false" title="<%= t('client.account.showPassword') %>">
                      <%- include('../partials/password-visibility-icons') %>
                    </button>
                  </span>
                </label>
                <div id="account-password-msg" class="account-form-msg" role="status" aria-live="polite" hidden></div>
                <div class="app-form-actions app-form-actions--account-save">
                  <button type="submit" class="app-btn-primary" id="account-password-submit"><%= t('account.updatePasswordButton') %></button>
                </div>
              </form>
            </section>

            <hr class="account-section-rule" aria-hidden="true" />

            <section class="account-rail-section">
              <h2 class="account-h2"><%= t('account.subscriptionH2') %></h2>
              <% if (typeof billingSummary !== 'undefined' && billingSummary.lines && billingSummary.lines.length) { %>
                <dl class="account-billing-summary" aria-label="<%= t('account.subscriptionH2') %>">
                  <% billingSummary.lines.forEach(function (row) { %>
                    <div class="account-billing-summary-row">
                      <dt><%= row.label %></dt>
                      <dd><%= row.value %></dd>
                    </div>
                  <% }); %>
                </dl>
              <% } %>
              <% if (appAccess.paid) { %>
                <p class="account-status account-status--paid"><%- t('account.activeMember') %></p>
              <% } else if (subscriptionRow && subscriptionRow.status === 'past_due') { %>
                <p class="account-status"><%- t('account.pastDue') %></p>
              <% } else if (appAccess.trialing && appAccess.trialEndsLabel) { %>
                <p class="account-status"><%= t('account.trialing') %></p>
              <% } else { %>
                <p class="account-status"><%= t('account.noSubscription') %></p>
              <% } %>

              <% if (showYearlyMonthlyWindowNotice) { %>
                <p class="account-meta account-meta--subscription-notice"><%= t('account.switchMonthlyWindow') %><% if (typeof renewalDateLabel !== 'undefined' && renewalDateLabel) { %> (<%= t('account.nextRenewalParen') %> <%= renewalDateLabel %>)<% } %>.</p>
              <% } %>
              <% var showPlanSwitch = showSubMaintain && typeof billingPriceMode !== 'undefined' && billingPriceMode === 'dual' && (currentPlanInterval === 'month' || (currentPlanInterval === 'year' && typeof within30DaysOfRenewal !== 'undefined' && within30DaysOfRenewal)); %>
              <% if (showSubMaintain || showPlanSwitch) { %>
                <div class="account-subscription-actions-row">
                  <% if (showSubMaintain) { %>
                    <div class="account-billing-maintain" id="account-subscription-actions">
                      <% if (capEnd) { %>
                        <button type="button" class="app-btn-primary" data-action="resume-subscription"><%= t('account.resumeRenewal') %></button>
                        <p class="account-meta"><%= t('account.resumeMeta') %></p>
                      <% } else { %>
                        <button type="button" class="app-btn-primary account-btn-yearly" data-action="cancel-at-period-end"><%= t('account.turnOffRenewal') %></button>
                      <% } %>
                      <div id="account-subscription-msg" class="account-form-msg" hidden></div>
                    </div>
                  <% } %>
                  <% if (showPlanSwitch) { %>
                    <div class="account-plan-switch" id="account-plan-switch">
                      <% if (currentPlanInterval === 'month') { %>
                        <button type="button" class="app-btn-primary account-btn-yearly" data-action="switch-plan" data-interval="year"><%= t('account.switchAnnualBilling') %></button>
                      <% } else { %>
                        <button type="button" class="app-btn-primary" data-action="switch-plan" data-interval="month"><%= t('account.planSwitchMonthly') %></button>
                        <p class="account-meta"><%= t('account.planSwitchProrate') %></p>
                      <% } %>
                      <div id="account-plan-switch-msg" class="account-form-msg" hidden></div>
                    </div>
                  <% } %>
                </div>
              <% } %>
              <% if (showPlanSwitch && currentPlanInterval === 'month') { %>
                <p id="account-plan-preview-estimate" class="account-plan-preview-estimate" hidden aria-live="polite"></p>
              <% } %>

              <% if (stripeConfigured && subscriptionRow && subscriptionRow.stripe_customer_id) { %>
                <p class="account-payment-links">
                  <a href="/billing/payment-method" class="app-link-cta"><%= t('account.updatePayment') %></a>
                  <button type="button" class="account-open-billing-history-btn" id="account-open-billing-history"><%= t('account.paymentHistory') %></button>
                </p>
              <% } %>

              <% if (!appAccess.paid) { %>
                <% if (stripeConfigured) { %>
                  <% if (billingPriceMode === 'dual') { %>
                    <div class="account-billing-choices">
                      <% if (typeof stripeElementsConfigured !== 'undefined' && stripeElementsConfigured) { %>
                        <a class="app-btn-primary" href="/billing/subscribe?interval=month"><%= t('account.subscribeMonthly') %></a>
                        <a class="app-btn-primary account-btn-yearly" href="/billing/subscribe?interval=year"><%= t('account.subscribeAnnual') %></a>
                      <% } else { %>
                        <a class="app-btn-primary" href="/billing/checkout?interval=month"><%= t('account.subscribeMonthly') %></a>
                        <a class="app-btn-primary account-btn-yearly" href="/billing/checkout?interval=year"><%= t('account.subscribeAnnual') %></a>
                      <% } %>
                    </div>
                    <% if (typeof stripeElementsConfigured !== 'undefined' && stripeElementsConfigured) { %>
                      <p class="account-meta"><%= t('account.billingSubscribeMetaOnSite') %></p>
                    <% } else { %>
                      <p class="account-meta"><%- t('account.billingCheckoutMeta') %></p>
                    <% } %>
                  <% } else { %>
                    <% if (typeof stripeElementsConfigured !== 'undefined' && stripeElementsConfigured) { %>
                      <p style="margin:.75rem 0 0"><a class="app-btn-primary" href="/billing/subscribe"><%= t('account.upgradeMember') %></a></p>
                      <p class="account-meta"><%= t('account.payOnNextPage') %></p>
                    <% } else { %>
                      <p style="margin:.75rem 0 0"><a class="app-btn-primary" href="/billing/checkout"><%= t('account.upgradeMember') %></a></p>
                      <p class="account-meta"><%- t('account.billingCheckoutMetaShort') %></p>
                    <% } %>
                  <% } %>
                <% } else { %>
                  <p class="account-meta"><%- t('account.billingNotConfigured') %></p>
                  <% if (typeof billingEnvMissing !== 'undefined' && billingEnvMissing.length) { %>
                    <p class="account-meta account-meta--warn"><%= t('account.missingEnv') %> <%= billingEnvMissing.join(', ') %></p>
                  <% } %>
                <% } %>
              <% } %>
            </section>

          </div>
        </div>
      </div>
    </main>
  </div>

  <div id="account-modal-cancel-renewal" class="account-modal-overlay" hidden>
    <div class="account-modal-overlay__backdrop" data-account-modal-dismiss="cancel-renewal" tabindex="-1" aria-hidden="true"></div>
    <div class="account-modal-overlay__panel" role="dialog" aria-modal="true" aria-labelledby="account-modal-cancel-renewal-title">
      <h3 id="account-modal-cancel-renewal-title" class="account-modal-overlay__title"><%= t('account.modalCancelTitle') %></h3>
      <p class="account-modal-overlay__text"><%= t('account.modalCancelText') %></p>
      <div class="account-modal-overlay__actions">
        <button type="button" class="account-modal-overlay__btn account-modal-overlay__btn--keep" data-account-modal-dismiss="cancel-renewal"><%= t('account.keepSubscription') %></button>
        <button type="button" class="account-modal-overlay__btn account-modal-overlay__btn--confirm-cancel" id="account-modal-cancel-renewal-confirm"><%= t('account.confirmCancel') %></button>
      </div>
    </div>
  </div>

  <% if (stripeConfigured && subscriptionRow && subscriptionRow.stripe_customer_id) { %>
  <div id="account-modal-billing-history" class="account-modal-overlay" hidden>
    <div class="account-modal-overlay__backdrop" data-account-modal-dismiss="billing-history" tabindex="-1" aria-hidden="true"></div>
    <div class="account-modal-overlay__panel account-modal-overlay__panel--billing-history" role="dialog" aria-modal="true" aria-labelledby="account-modal-billing-history-title">
      <h3 id="account-modal-billing-history-title" class="account-modal-overlay__title"><%= t('account.paymentHistoryTitle') %></h3>
      <p class="account-modal-overlay__text"><%= t('account.paymentHistoryIntro') %></p>
      <% if (typeof billingHistory !== 'undefined' && billingHistory.length) { %>
        <div class="account-table-scroll account-modal-billing-history-scroll" role="region" aria-label="<%= t('account.billingHistoryTableAria') %>">
          <table class="account-billing-history-table">
            <thead>
              <tr>
                <th scope="col"><%= t('account.tableDate') %></th>
                <th scope="col"><%= t('account.tableDescription') %></th>
                <th scope="col"><%= t('account.tableAmount') %></th>
                <th scope="col"><%= t('account.tableStatus') %></th>
              </tr>
            </thead>
            <tbody>
              <% billingHistory.forEach(function (row) { %>
                <tr>
                  <td><%= row.dateLabel %></td>
                  <td><%= row.description %></td>
                  <td><%= row.amountLabel %></td>
                  <td><%= row.statusLabel %></td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <p class="account-modal-overlay__text"><%= t('account.noInvoices') %></p>
      <% } %>
      <div class="account-modal-overlay__actions">
        <button type="button" class="account-modal-overlay__btn account-modal-overlay__btn--secondary" data-account-modal-dismiss="billing-history"><%= t('account.close') %></button>
      </div>
    </div>
  </div>
  <% } %>

  <div id="account-modal-yearly-plan" class="account-modal-overlay" hidden>
    <div class="account-modal-overlay__backdrop" data-account-modal-dismiss="yearly-plan" tabindex="-1" aria-hidden="true"></div>
    <div class="account-modal-overlay__panel" role="dialog" aria-modal="true" aria-labelledby="account-modal-yearly-title">
      <h3 id="account-modal-yearly-title" class="account-modal-overlay__title"><%= t('account.yearlyConfirmTitle') %></h3>
      <p class="account-modal-overlay__text"><%= t('account.yearlyConfirmLead') %></p>
      <p id="account-modal-yearly-amount" class="account-modal-overlay__text account-modal-overlay__text--estimate-amount" aria-live="polite"></p>
      <p class="account-modal-overlay__text"><%= t('account.yearlyConfirmDisclaimer') %></p>
      <div class="account-modal-overlay__actions">
        <button type="button" class="account-modal-overlay__btn account-modal-overlay__btn--secondary" data-account-modal-dismiss="yearly-plan"><%= t('client.common.cancel') %></button>
        <button type="button" class="account-modal-overlay__btn account-modal-overlay__btn--confirm-mint" id="account-modal-yearly-confirm"><%= t('account.confirm') %></button>
      </div>
    </div>
  </div>

  <script src="/js/account.js" defer></script>
</body>
</html>
