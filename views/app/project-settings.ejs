<!DOCTYPE html>
<html lang="<%= typeof htmlLang !== 'undefined' ? htmlLang : 'en' %>" dir="<%= typeof textDir !== 'undefined' ? textDir : 'ltr' %>">
<head>
  <% var title = t('project.settingsTitle'); %>
  <%- include('../partials/app-head') %>
</head>
<body class="app-body app-body--account-page">
  <div class="app-grid app-grid--account">
    <%- include('../partials/app-sidebar', { user: user, navActive: 'workspace', projects: projects, currentProjectId: currentProjectId, workspaceSlug: typeof workspaceSlug !== 'undefined' ? workspaceSlug : '', appAccess: appAccess }) %>
    <main class="app-canvas">
      <h1><%= t('project.settingsTitle') %></h1>
      <p class="sub"><%= t('project.settingsSub') %></p>

      <% if (typeof query !== 'undefined' && query && query.saved) { %>
        <div class="account-flash account-flash--ok" role="status"><%= t('project.settingsSaved') %></div>
      <% } %>
      <% if (error) { %>
        <div class="app-form-error" role="alert"><%= error %></div>
      <% } %>

      <% var proj = bundle.project; %>
      <% var isOtherTemplate = proj.template_key === 'other'; %>

      <form id="project-settings-form" class="app-form-stack project-settings-form" method="post" action="/app/project/<%= bundle.project.id %>/settings">
        <label class="app-field">
          <span><%= t('project.name') %></span>
          <input type="text" name="name" required maxlength="255" value="<%= proj.name %>" autocomplete="off" />
        </label>
        <label class="app-field">
          <span><%= t('project.purpose') %></span>
          <select id="settings-purpose" name="purpose" required>
            <% purposes.forEach(function(pk) { %>
              <option value="<%= pk %>" <%= proj.purpose === pk ? 'selected' : '' %>><%= t('projectPurposes.' + pk) %></option>
            <% }); %>
          </select>
        </label>
        <label class="app-field project-purpose-other-wrap" id="settings-purpose-other-wrap" <%= proj.purpose === 'other' ? '' : 'hidden' %>>
          <span><%= t('project.purposeOther') %> <span class="account-optional"><%= t('project.purposeOtherOptional') %></span></span>
          <input type="text" name="purposeOther" maxlength="500" value="<%= proj.purpose_other || '' %>" placeholder="<%= t('project.purposeOtherPlaceholder') %>" autocomplete="off" />
        </label>
        <label class="app-field">
          <span><%= t('project.citationStyle') %></span>
          <select name="citationStyle" required>
            <% citationStyles.forEach(function(c) { %>
              <option value="<%= c %>" <%= proj.citation_style === c ? 'selected' : '' %>><%= t('citationStyles.' + String(c).toLowerCase()) %></option>
            <% }); %>
          </select>
        </label>
        <label class="app-field">
          <span><%= t('project.template') %></span>
          <input type="text" readonly value="<%= templateLabel %>" class="project-settings-template-readonly" aria-readonly="true" />
        </label>

        <% if (isOtherTemplate) { %>
          <div class="project-settings-other-sections">
            <p class="account-meta"><%= t('project.settingsOtherSectionsMeta') %></p>
            <div id="settings-other-rows">
              <% bundle.sections.forEach(function (sec) { %>
                <div class="project-other-row project-settings-other-row" data-section-id="<%= sec.id %>">
                  <label class="app-field project-other-row-title">
                    <span><%= t('project.sectionName') %></span>
                    <input type="text" class="js-section-title" maxlength="255" required value="<%= sec.title %>" autocomplete="off" />
                  </label>
                  <label class="app-field project-other-row-pct">
                    <span><%= t('project.percentOfWhole') %></span>
                    <input type="number" class="js-section-pct" min="0" max="100" step="1" required value="<%= sec.progress_percent %>" />
                  </label>
                </div>
              <% }); %>
            </div>
            <p class="project-other-sections-sum" id="settings-other-sum" aria-live="polite"></p>
          </div>
          <input type="hidden" name="otherSectionsJson" id="otherSectionsJson" value="" />
        <% } %>

        <div class="app-form-actions">
          <button type="submit" class="app-btn-primary"><%= t('project.saveChanges') %></button>
        </div>
      </form>
    </main>
  </div>
  <% var _psI18n = JSON.stringify({
    sumPrefix: t('project.settingsSumPrefix'),
    sumOk: t('project.settingsSumOk'),
    sumMust100: t('project.settingsSumMust100'),
    alertPct100: t('project.settingsAlertPct100'),
    alertSectionName: t('project.settingsAlertSectionName')
  }).replace(/</g, '\\u003c'); %>
  <script id="project-settings-i18n" type="application/json"><%- _psI18n %></script>
  <script src="/js/project-settings.js" defer></script>
</body>
</html>
