<!DOCTYPE html>
<html lang="<%= typeof htmlLang !== 'undefined' ? htmlLang : 'en' %>" dir="<%= typeof textDir !== 'undefined' ? textDir : 'ltr' %>">
<head>
  <% var title = typeof phaseTitle !== 'undefined' ? phaseTitle : 'Workspace'; %>
  <%- include('../partials/app-head') %>
  <% if (phaseSlug === 'anvil') { %>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.snow.css" crossorigin="anonymous" />
  <% } %>
  <% if (phaseSlug === 'framework') { %>
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:ital,wght@0,300;0,400;1,300&display=swap" rel="stylesheet" />
  <% } %>
</head>
<body class="app-body app-body--workspace-shell<%= phaseSlug === 'anvil' ? ' app-body--anvil' : '' %><%= phaseSlug === 'crucible' ? ' app-body--crucible' : '' %><%= phaseSlug === 'framework' ? ' app-body--research-anatomy' : '' %>">
  <div class="app-grid">
    <%- include('../partials/app-sidebar', { user: user, navActive: 'workspace', projects: projects, currentProjectId: currentProjectId, workspaceSlug: phaseSlug, appAccess: appAccess, anvilSections: typeof anvilSections !== 'undefined' ? anvilSections : [], anvilSectionId: typeof anvilSectionId !== 'undefined' ? anvilSectionId : null }) %>
    <main class="app-canvas">
      <% if (appAccess.trialing && !appAccess.paid && appAccess.trialEndsLabel) { %>
        <div class="app-trial-bar"><%- t('workspace.trialBarFoundry', { date: appAccess.trialEndsLabel }) %></div>
      <% } %>
      <% if (phaseSlug === 'anvil') { %>
        <div class="app-anvil-page-head" id="tw-anvil-head">
          <div class="app-anvil-page-head__left">
            <h1><%= phaseTitle %></h1>
            <p class="sub app-anvil-intro"><%= t('workspace.anvilIntro') %></p>
          </div>
          <div id="tw-anvil-scoring-metrics" class="anvil-scoring-metrics-wrap">
            <div id="anvil-scoring-panel" class="anvil-top-metrics__scoring app-anvil-scoring-head" hidden aria-live="polite"></div>
          </div>
        </div>
      <% } else if (phaseSlug !== 'framework') { %>
      <h1><%= phaseTitle %></h1>
      <% } %>
      <% if (phaseSlug === 'crucible') { %>
        <p class="sub app-crucible-intro"><%= t('workspace.crucibleIntro') %></p>
      <% } else if (phaseSlug !== 'anvil' && phaseSlug !== 'framework') { %>
        <p class="sub"><%= t('workspace.genericPhaseSub', { project: projectTitle }) %></p>
      <% } %>

      <% if (foundryLocked) { %>
        <div class="app-paywall" id="tw-foundry-paywall">
          <h2><%= t('workspace.foundryPaywallTitle') %></h2>
          <p><%= t('workspace.foundryPaywallBody') %></p>
        </div>
      <% } else if (phaseSlug === 'anvil') { %>
        <div
          id="anvil-root"
          class="anvil"
          data-project-id="<%= projectId %>"
          data-initial-idle-ms="<%= typeof anvilInitialIdleMs !== 'undefined' ? anvilInitialIdleMs : 1800 %>"
          data-incremental-chars="<%= typeof anvilIncrementalChars !== 'undefined' ? anvilIncrementalChars : 40 %>"
          data-autosave-chars="<%= typeof autosaveCharThreshold !== 'undefined' ? autosaveCharThreshold : 250 %>"
          data-score-strong="<%= typeof scoreStrongThreshold !== 'undefined' ? scoreStrongThreshold : 0.05 %>"
          data-score-moderate="<%= typeof scoreModerateThreshold !== 'undefined' ? scoreModerateThreshold : 0.15 %>"
        ></div>
      <% } else if (phaseSlug === 'crucible') { %>
        <div id="crucible-root" class="crucible"
          data-project-id="<%= projectId %>"
          data-citation-style="<%= typeof crucibleCitationStyle !== 'undefined' ? crucibleCitationStyle : 'APA' %>"
          data-sections="<%= encodeURIComponent(JSON.stringify((typeof crucibleSections !== 'undefined' ? crucibleSections : []).map(function(s){ return { id: s.id, title: s.title, slug: s.slug != null ? String(s.slug) : '' }; }))) %>">
        </div>
      <% } else if (phaseSlug === 'framework') { %>
        <%- include('../partials/research-anatomy-stage') %>
      <% } else { %>
        <div class="app-placeholder" id="tw-foundry-workspace">
          <strong><%= t('workspace.placeholderStrong') %></strong> <%= t('workspace.placeholderRest') %> <code><%= phaseSlug %></code>.
        </div>
      <% } %>
    </main>
    <% if (phaseSlug === 'anvil') { %>
      <%- include('../partials/app-anvil-rail') %>
    <% } else if (phaseSlug === 'crucible') { %>
      <%- include('../partials/app-crucible-rail') %>
    <% } else if (phaseSlug === 'framework') { %>
      <%- include('../partials/app-research-anatomy-rail') %>
    <% } else { %>
      <%- include('../partials/app-insight-panel', { insightHint: insightHint || t('workspace.insightFallback') }) %>
    <% } %>
  </div>
  <% if (phaseSlug === 'anvil') { %>
  <script src="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.min.js" crossorigin="anonymous"></script>
  <script src="/js/anvil.js" defer></script>
  <% } else if (phaseSlug === 'crucible') { %>
  <script src="/js/crucible.js" defer></script>
  <% } else if (phaseSlug === 'framework') { %>
  <script>
    window.__RA_I18N__ = {
      btnInitiate: <%- JSON.stringify(t('workspace.researchAnatomy.btnInitiate')) %>,
      btnRereview: <%- JSON.stringify(t('workspace.researchAnatomy.btnRereview')) %>,
      cooldownPrefix: <%- JSON.stringify(t('workspace.researchAnatomy.cooldownPrefix')) %>,
      statusProcessing: <%- JSON.stringify(t('workspace.researchAnatomy.statusProcessing')) %>,
      statusError: <%- JSON.stringify(t('workspace.researchAnatomy.statusError')) %>,
      bedrockMissing: <%- JSON.stringify(t('workspace.researchAnatomy.bedrockMissing')) %>,
      minWords: <%= typeof minReviewWords !== 'undefined' ? minReviewWords : 100 %>
    };
  </script>
  <script src="/js/research-anatomy.js" defer></script>
  <% } %>
</body>
</html>
