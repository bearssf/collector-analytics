<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/app-head', { title: phaseTitle }) %>
</head>
<body class="app-body">
  <div class="app-grid">
    <%- include('../partials/app-sidebar', { user: user, navActive: 'workspace', projects: projects, currentProjectId: currentProjectId, workspaceSlug: phaseSlug, appAccess: appAccess }) %>
    <main class="app-canvas">
      <% if (appAccess.trialing && !appAccess.paid && appAccess.trialEndsLabel) { %>
        <div class="app-trial-bar">Free trial — ends <%= appAccess.trialEndsLabel %>. The Foundry requires a paid plan.</div>
      <% } %>
      <h1><%= phaseTitle %></h1>
      <% if (phaseSlug === 'crucible') { %>
        <p class="sub">Citations and notes for <strong><%= projectTitle %></strong> — link sources to your outline sections.</p>
      <% } else if (phaseSlug === 'anvil') { %>
        <p class="sub">Section drafts for <strong><%= projectTitle %></strong> — autosaves to your project outline.</p>
      <% } else if (phaseSlug === 'framework') { %>
        <p class="sub">Argument outline for <strong><%= projectTitle %></strong> — track status and progress per section.</p>
      <% } else { %>
        <p class="sub"><%= projectTitle %> — center canvas placeholder. Rich editor, sources, and workflow tools will mount here.</p>
      <% } %>

      <% if (foundryLocked) { %>
        <div class="app-paywall">
          <h2>The Foundry is for members</h2>
          <p>The Foundry is not included in the free trial. Subscribe to unlock literature-gap and topic ideation powered by your sources and interests.</p>
        </div>
      <% } else if (phaseSlug === 'crucible') { %>
        <div id="crucible-root" class="crucible" data-project-id="<%= projectId %>"></div>
        <script src="/js/crucible.js" defer></script>
      <% } else if (phaseSlug === 'anvil') { %>
        <div id="anvil-root" class="anvil" data-project-id="<%= projectId %>"></div>
        <script src="/js/anvil.js" defer></script>
      <% } else if (phaseSlug === 'framework') { %>
        <div id="framework-root" class="framework" data-project-id="<%= projectId %>"></div>
        <script src="/js/framework.js" defer></script>
      <% } else { %>
        <div class="app-placeholder">
          <strong>Placeholder workspace.</strong> Section-specific writing, capture, or visualization will load here for <code><%= phaseSlug %></code>.
        </div>
      <% } %>
    </main>
    <%- include('../partials/app-insight-panel', { insightHint: insightHint || 'Feedback and suggestions for this step will appear here.' }) %>
  </div>
</body>
</html>
