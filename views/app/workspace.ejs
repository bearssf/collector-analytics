<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/app-head', { title: phaseTitle }) %>
  <% if (phaseSlug === 'anvil') { %>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.snow.css" crossorigin="anonymous" />
  <% } %>
</head>
<body class="app-body app-body--workspace-shell<%= phaseSlug === 'anvil' ? ' app-body--anvil' : '' %><%= phaseSlug === 'crucible' ? ' app-body--crucible' : '' %>">
  <div class="app-grid">
    <%- include('../partials/app-sidebar', { user: user, navActive: 'workspace', projects: projects, currentProjectId: currentProjectId, workspaceSlug: phaseSlug, appAccess: appAccess, anvilSections: typeof anvilSections !== 'undefined' ? anvilSections : [], anvilSectionId: typeof anvilSectionId !== 'undefined' ? anvilSectionId : null }) %>
    <main class="app-canvas">
      <% if (appAccess.trialing && !appAccess.paid && appAccess.trialEndsLabel) { %>
        <div class="app-trial-bar">Free trial — ends <%= appAccess.trialEndsLabel %>. The Foundry requires a paid plan.</div>
      <% } %>
      <h1><%= phaseTitle %></h1>
      <% if (phaseSlug === 'anvil') { %>
        <p class="sub app-anvil-intro">Forge draft for <strong><%= projectTitle %></strong>.</p>
      <% } else if (phaseSlug === 'crucible') { %>
        <p class="sub app-crucible-intro">Where ideas stop drifting and start taking shape through the inclusion and management of your research sources.</p>
      <% } else if (phaseSlug === 'framework') { %>
        <p class="sub">Argument outline and evidence mapping for <strong><%= projectTitle %></strong>.</p>
      <% } else { %>
        <p class="sub"><%= projectTitle %> — center canvas placeholder. Rich editor, sources, and workflow tools will mount here.</p>
      <% } %>

      <% if (foundryLocked) { %>
        <div class="app-paywall">
          <h2>The Foundry is for members</h2>
          <p>The Foundry is not included in the free trial. Subscribe to unlock literature-gap and topic ideation powered by your sources and interests.</p>
        </div>
      <% } else if (phaseSlug === 'anvil') { %>
        <div
          id="anvil-root"
          class="anvil"
          data-project-id="<%= projectId %>"
          data-initial-idle-ms="<%= typeof anvilInitialIdleMs !== 'undefined' ? anvilInitialIdleMs : 1800 %>"
          data-incremental-chars="<%= typeof anvilIncrementalChars !== 'undefined' ? anvilIncrementalChars : 40 %>"
        ></div>
      <% } else if (phaseSlug === 'crucible') { %>
        <div id="crucible-root" class="crucible"
          data-project-id="<%= projectId %>"
          data-citation-style="<%= typeof crucibleCitationStyle !== 'undefined' ? crucibleCitationStyle : 'APA' %>"
          data-sections="<%= encodeURIComponent(JSON.stringify((typeof crucibleSections !== 'undefined' ? crucibleSections : []).map(function(s){ return { id: s.id, title: s.title }; }))) %>">
        </div>
      <% } else if (phaseSlug === 'framework') { %>
        <div class="app-placeholder">
          <p style="margin:0 0 .5rem"><strong>Coming soon.</strong> The Framework workspace isn’t wired up yet—we’ll revisit the right experience for outline and evidence here.</p>
          <p style="margin:0;color:rgba(255,255,255,.55);font-size:.9rem">The Anvil already covers section drafts for this project.</p>
        </div>
      <% } else { %>
        <div class="app-placeholder">
          <strong>Placeholder workspace.</strong> Section-specific writing, capture, or visualization will load here for <code><%= phaseSlug %></code>.
        </div>
      <% } %>
    </main>
    <% if (phaseSlug === 'anvil') { %>
      <%- include('../partials/app-anvil-rail') %>
    <% } else if (phaseSlug === 'crucible') { %>
      <%- include('../partials/app-crucible-rail') %>
    <% } else { %>
      <%- include('../partials/app-insight-panel', { insightHint: insightHint || 'Feedback and suggestions for this step will appear here.' }) %>
    <% } %>
  </div>
  <% if (phaseSlug === 'anvil') { %>
  <script src="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.min.js" crossorigin="anonymous"></script>
  <script src="/js/anvil.js" defer></script>
  <% } else if (phaseSlug === 'crucible') { %>
  <script src="/js/crucible.js" defer></script>
  <% } %>
</body>
</html>
