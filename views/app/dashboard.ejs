<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/app-head', { title: 'Portfolio dashboard' }) %>
</head>
<body class="app-body app-body--workspace-shell">
  <div class="app-grid">
    <%- include('../partials/app-sidebar', { user: user, navActive: 'dashboard', projects: projects, currentProjectId: currentProjectId, workspaceSlug: '', appAccess: appAccess }) %>
    <main class="app-canvas">
      <% if (appAccess.trialing && !appAccess.paid && appAccess.trialEndsLabel) { %>
        <div class="app-trial-bar">Free trial active — ends <%= appAccess.trialEndsLabel %>. Upgrade to unlock <strong>The Foundry</strong> and full membership.</div>
      <% } %>
      <h1>Forge portfolio</h1>
      <p class="sub">Your projects and quick entry into each workspace.</p>

      <% if (projects && projects.length) { %>
        <ul class="app-dashboard-list">
          <% projects.forEach(function(p) { %>
            <li class="app-dashboard-item">
              <a href="/app/project/<%= p.id %>/anvil" class="app-dashboard-card">
                <strong><%= p.name %></strong>
                <span class="muted"><%= p.purpose %> · <%= p.citation_style %></span>
              </a>
              <button type="button" class="app-dashboard-delete" data-project-id="<%= p.id %>" data-project-name="<%= encodeURIComponent(p.name) %>" title="Delete project">Delete</button>
            </li>
          <% }); %>
        </ul>
        <p class="app-dashboard-actions"><a href="/app/projects/new" class="app-link-cta">+ Forge a new project</a></p>
      <% } else { %>
        <div class="app-placeholder">
          <p style="margin:0 0 .75rem">No projects yet. Forge one to start with The Anvil, Crucible, and Framework.</p>
          <p style="margin:0"><a href="/app/projects/new" class="app-btn-primary">Forge a new project</a></p>
        </div>
      <% } %>
    </main>
    <%- include('../partials/app-insight-panel', { insightHint: 'Portfolio-level insights and reminders will appear here.' }) %>
  </div>
  <script src="/js/dashboard.js"></script>
</body>
</html>
