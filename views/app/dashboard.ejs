<!DOCTYPE html>
<html lang="<%= typeof htmlLang !== 'undefined' ? htmlLang : 'en' %>" dir="<%= typeof textDir !== 'undefined' ? textDir : 'ltr' %>">
<head>
  <% var title = t('dashboard.title'); %>
  <%- include('../partials/app-head') %>
</head>
<body class="app-body app-body--workspace-shell app-body--dashboard">
  <%
    var _purposeSlug = { 'Academic Assignment': 'academicAssignment', 'Academic Publication': 'academicPublication', 'Conference': 'conference', 'Dissertation/Thesis': 'dissertationThesis', 'Other': 'other' };
    var _purposeKeys = { academicAssignment: 1, academicPublication: 1, conference: 1, dissertationThesis: 1, other: 1 };
    function formatPurpose(purpose) {
      if (!purpose) return '';
      var slug = _purposeSlug[purpose] || purpose;
      if (_purposeKeys[slug]) return t('projectPurposes.' + slug);
      return purpose;
    }
    var _citeSlug = { APA: 'apa', MLA: 'mla', Chicago: 'chicago', Turabian: 'turabian', IEEE: 'ieee' };
    function formatCitation(cs) {
      var s = _citeSlug[cs];
      return s ? t('citationStyles.' + s) : (cs || '');
    }
  %>
  <div class="app-grid">
    <%- include('../partials/app-sidebar', { user: user, navActive: 'dashboard', projects: projects, currentProjectId: currentProjectId, workspaceSlug: '', appAccess: appAccess }) %>
    <main class="app-canvas app-canvas--dashboard">
      <% if (appAccess.trialing && !appAccess.paid && appAccess.trialEndsLabel) { %>
        <div class="app-trial-bar"><%- t('dashboard.trialBar', { date: appAccess.trialEndsLabel }) %></div>
      <% } %>
      <% var progressData = typeof projectProgress !== 'undefined' ? projectProgress : []; %>
      <% var recentProject = projects && projects.length ? projects[0] : null; %>
      <% var portfolioRows = []; %>
      <% progressData.forEach(function(pp) { %>
        <% var pr = projects.find(function(x) { return x.id === pp.id; }); %>
        <% if (pr && pr.dashCat !== 'canceled') portfolioRows.push(pp); %>
      <% }); %>
      <% var portfolioWords = 0, portfolioTarget = 0; %>
      <% portfolioRows.forEach(function(pp) { portfolioWords += pp.totalWords; portfolioTarget += pp.target; }); %>
      <% var portfolioPct = portfolioTarget > 0 ? Math.min(100, Math.round((portfolioWords / portfolioTarget) * 100)) : 0; %>
      <% var foundryHref = typeof foundryProjectId !== 'undefined' && foundryProjectId ? '/app/project/' + foundryProjectId + '/foundry' : '#'; %>

      <div class="dash-canvas-head" id="tw-portfolio-head">
        <div class="dash-canvas-head__titles">
          <h1><%= t('dashboard.forgePortfolio') %></h1>
          <p class="sub"><%= t('dashboard.sub') %></p>
        </div>
        <a href="/app/projects/new" class="app-btn-primary dash-add-project-btn" id="tw-portfolio-add-project"><%= t('dashboard.addProject') %></a>
      </div>

      <% if (recentProject && progressData.length) { %>
      <div class="dash-recent-bar" id="tw-portfolio-active-project">
        <label class="dash-recent-bar__label" for="dash-active-project-select"><%= t('dashboard.activeProject') %></label>
        <select id="dash-active-project-select" class="dash-active-project-select" aria-label="<%= t('dashboard.ariaActiveProject') %>">
          <% projects.forEach(function(p) { %>
            <option value="<%= p.id %>" <%= p.id === recentProject.id ? 'selected' : '' %>><%= p.name %></option>
          <% }); %>
        </select>
      </div>
      <% } %>

      <div class="dash-visuals" id="tw-portfolio-metrics">
        <% if (recentProject && progressData.length) { %>
        <% var recentProg = progressData.find(function(pp) { return pp.id === recentProject.id; }); %>
        <div class="dash-visual-card" id="dash-active-visual" data-project-id="<%= recentProject.id %>">
          <div class="dash-visual-card__title"><%= recentProject.name %></div>
          <div class="dash-ring-wrap">
            <svg class="dash-ring" viewBox="0 0 120 120" aria-hidden="true">
              <circle class="dash-ring__bg" cx="60" cy="60" r="52" />
              <circle class="dash-ring__fill dash-ring__fill--active" cx="60" cy="60" r="52" stroke-dasharray="<%= Math.round(326.7 * (recentProg ? recentProg.pct : 0) / 100) %> 327" />
              <text class="dash-ring__text" x="60" y="66"><%= recentProg ? recentProg.pct : 0 %>%</text>
            </svg>
          </div>
          <div class="dash-visual-card__sub"><%= t('dashboard.projectCompletion') %></div>
          <div class="dash-section-bars-header">
            <div class="dash-section-bars-header__graph-spacer" aria-hidden="true"></div>
            <div class="dash-section-bars-header__metrics">
              <span class="dash-section-bars-header__col"><%= t('dashboard.wordsCompleted') %></span>
              <span class="dash-section-bars-header__col"><%= t('dashboard.researchOutstanding') %></span>
            </div>
          </div>
          <div class="dash-section-bars" id="dash-active-section-bars">
            <% if (recentProg && recentProg.sections && recentProg.sections.length) { %>
            <% recentProg.sections.forEach(function(sec) { %>
            <div class="dash-section-bar">
              <div class="dash-section-bar__graph">
                <span class="dash-section-bar__label" title="<%= sectionLabel(sec) %>"><%= sectionLabel(sec) %></span>
                <div class="dash-section-bar__track"><div class="dash-section-bar__fill" style="width:<%= sec.pct %>%"></div></div>
                <span class="dash-section-bar__pct"><%= sec.pct %>%</span>
              </div>
              <div class="dash-section-bar__metrics">
                <div class="dash-section-bar__metric">
                  <span class="dash-section-bar__metric-value"><%= sec.words.toLocaleString() %></span>
                </div>
                <div class="dash-section-bar__metric">
                  <span class="dash-section-bar__metric-value"><%= sec.researchOpen %></span>
                </div>
              </div>
            </div>
            <% }); %>
            <% } %>
          </div>
        </div>
        <% } %>

        <% if (portfolioRows.length) { %>
        <div class="dash-visual-card" id="dash-portfolio-visual">
          <div class="dash-visual-card__title"><%= t('dashboard.allProjects') %></div>
          <div class="dash-ring-wrap">
            <svg class="dash-ring" viewBox="0 0 120 120" aria-hidden="true">
              <circle class="dash-ring__bg" cx="60" cy="60" r="52" />
              <circle class="dash-ring__fill dash-ring__fill--portfolio" cx="60" cy="60" r="52" stroke-dasharray="<%= Math.round(326.7 * portfolioPct / 100) %> 327" />
              <text class="dash-ring__text" x="60" y="66"><%= portfolioPct %>%</text>
            </svg>
          </div>
          <div class="dash-visual-card__sub"><%= t('dashboard.portfolioCompletion') %></div>
          <div class="dash-section-bars-header">
            <div class="dash-section-bars-header__graph-spacer" aria-hidden="true"></div>
            <div class="dash-section-bars-header__metrics">
              <span class="dash-section-bars-header__col"><%= t('dashboard.wordsCompleted') %></span>
              <span class="dash-section-bars-header__col"><%= t('dashboard.researchOutstanding') %></span>
            </div>
          </div>
          <div class="dash-section-bars">
            <% portfolioRows.forEach(function(pp) { %>
            <div class="dash-section-bar">
              <div class="dash-section-bar__graph">
                <span class="dash-section-bar__label" title="<%= pp.name %>"><%= pp.name %></span>
                <div class="dash-section-bar__track"><div class="dash-section-bar__fill" style="width:<%= pp.pct %>%"></div></div>
                <span class="dash-section-bar__pct"><%= pp.pct %>%</span>
              </div>
              <div class="dash-section-bar__metrics">
                <div class="dash-section-bar__metric">
                  <span class="dash-section-bar__metric-value"><%= pp.totalWords.toLocaleString() %></span>
                </div>
                <div class="dash-section-bar__metric">
                  <span class="dash-section-bar__metric-value"><%= pp.researchOpenTotal %></span>
                </div>
              </div>
            </div>
            <% }); %>
          </div>
        </div>
        <% } %>
      </div>

      <% var researchIdeasList = typeof researchIdeas !== 'undefined' && researchIdeas ? researchIdeas : []; %>
      <% var publishedWorkList = typeof publishedWork !== 'undefined' && publishedWork ? publishedWork : []; %>
      <div class="dash-ideas-tile dash-ideas-tile--with-list" id="tw-portfolio-ideas">
        <div class="dash-ideas-tile__head">
          <div class="dash-ideas-tile__text">
            <div class="dash-ideas-tile__title"><%= t('dashboard.researchIdeasTitle') %></div>
            <p class="dash-ideas-tile__hint"><%= t('dashboard.researchIdeasHintBefore') %> <a href="<%= foundryHref %>" class="dash-ideas-tile__link"><%= t('dashboard.foundryLink') %></a><%= t('dashboard.researchIdeasHintAfter') %></p>
          </div>
          <button type="button" class="app-btn-primary dash-ideas-tile__btn" id="dash-open-research-modal"><%= t('dashboard.trackResearchIdeas') %></button>
        </div>
        <% if (researchIdeasList.length) { %>
        <div class="dash-saved-tiles" role="list">
          <% researchIdeasList.forEach(function(idea) { %>
          <div class="dash-saved-tile dash-saved-tile--idea" role="listitem">
            <div class="dash-saved-tile__title"><%= idea.research_topic %></div>
            <% if (idea.keywords) { %><div class="dash-saved-tile__meta"><%= idea.keywords %></div><% } %>
            <% if (idea.notes) { %><p class="dash-saved-tile__notes"><%= idea.notes.length > 220 ? idea.notes.slice(0, 220) + '…' : idea.notes %></p><% } %>
          </div>
          <% }); %>
        </div>
        <% } %>
      </div>

      <div class="dash-ideas-tile dash-published-tile dash-ideas-tile--with-list" id="tw-portfolio-published">
        <div class="dash-ideas-tile__head">
          <div class="dash-ideas-tile__text">
            <div class="dash-ideas-tile__title dash-ideas-tile__title--published"><%= t('dashboard.publishedWorkTitle') %></div>
            <p class="dash-ideas-tile__hint"><%= t('dashboard.publishedWorkHint') %></p>
          </div>
          <button type="button" class="app-btn-primary dash-ideas-tile__btn" id="dash-open-published-modal"><%= t('dashboard.recordPublishedWork') %></button>
        </div>
        <% if (publishedWorkList.length) { %>
        <div class="dash-saved-tiles" role="list">
          <% publishedWorkList.forEach(function(pub) { %>
          <div class="dash-saved-tile dash-saved-tile--published" role="listitem">
            <div class="dash-saved-tile__title"><%= pub.title %></div>
            <div class="dash-saved-tile__meta">
              <% if (pub.date_published) { %><span><%= pub.date_published %></span><% } %>
              <% if (pub.date_published && pub.where_published) { %> · <% } %>
              <% if (pub.where_published) { %><span><%= pub.where_published %></span><% } %>
            </div>
            <% if (pub.link) { %><a href="<%= pub.link %>" class="dash-saved-tile__link" target="_blank" rel="noopener noreferrer"><%= t('dashboard.viewLink') %></a><% } %>
          </div>
          <% }); %>
        </div>
        <% } %>
      </div>
    </main>

    <aside class="app-insight app-insight--dashboard">
      <div class="dash-rail-top">
        <div class="dash-rail-head-row" id="tw-dash-rail-filter">
          <div class="insight-h"><%= t('dashboard.railHeading') %></div>
          <select id="dash-project-filter" class="dash-project-filter" aria-label="<%= t('dashboard.filterAria') %>">
            <option value="active-completed" selected><%= t('dashboard.filterActiveCompleted') %></option>
            <option value="active"><%= t('dashboard.filterActive') %></option>
            <option value="completed"><%= t('dashboard.filterCompleted') %></option>
            <option value="canceled"><%= t('dashboard.filterCanceled') %></option>
          </select>
        </div>
        <div class="dash-rail-projects" id="dash-rail-projects">
          <% if (projects && projects.length) { %>
            <% projects.forEach(function(p) { %>
              <div class="dash-rail-project-tile" data-dash-cat="<%= p.dashCat %>">
                <button type="button" class="dash-rail-tile-cancel" aria-label="<%= t('dashboard.cancelProjectAria') %>" title="<%= t('dashboard.cancelProjectAria') %>" data-project-id="<%= p.id %>" data-project-name="<%= encodeURIComponent(p.name) %>">
                  <svg class="dash-rail-tile-cancel__icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                    <circle cx="12" cy="12" r="9" fill="none" stroke="currentColor" stroke-width="1.75"/>
                    <path fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" d="M8.5 8.5l7 7m0-7l-7 7"/>
                  </svg>
                </button>
                <a href="/app/project/<%= p.id %>/anvil" class="dash-rail-project-tile__name"><%= p.name %></a>
                <div class="dash-rail-project-tile__row">
                  <span class="dash-rail-project-tile__meta"><%= formatPurpose(p.purpose) %> · <%= formatCitation(p.citation_style) %></span>
                  <span class="dash-rail-project-tile__actions">
                    <a href="/app/project/<%= p.id %>/settings" class="dash-rail-tile-action"><%= t('dashboard.edit') %></a>
                    <button type="button" class="dash-rail-tile-action dash-rail-tile-action--del app-dashboard-delete" data-project-id="<%= p.id %>" data-project-name="<%= encodeURIComponent(p.name) %>"><%= t('dashboard.delete') %></button>
                  </span>
                </div>
              </div>
            <% }); %>
            <p id="dash-rail-filter-empty" class="dash-rail-filter-empty" hidden><%= t('dashboard.noProjectsMatchFilter') %></p>
          <% } else { %>
            <p class="dash-rail-empty"><%= t('dashboard.noProjectsYet') %></p>
          <% } %>
        </div>
      </div>
      <div class="dash-rail-bottom" id="tw-dash-account-status">
        <% var bLines = typeof billingSummary !== 'undefined' && billingSummary && billingSummary.lines ? billingSummary.lines : []; %>
        <% if (appAccess.paid || bLines.length) { %>
          <% bLines.forEach(function(row) { %>
            <div class="dash-rail-renewal">
              <span class="dash-rail-renewal__label"><%= row.label %>:</span>
              <span class="dash-rail-renewal__date"><%= row.value %></span>
            </div>
          <% }); %>
          <a href="/app/account" class="dash-rail-renewal__link"><%= t('dashboard.manageSubscription') %></a>
        <% } else { %>
          <div class="dash-rail-renewal">
            <span class="dash-rail-renewal__label"><%= t('dashboard.noActiveSubscription') %></span>
          </div>
          <a href="/app/account" class="dash-rail-renewal__link"><%= t('dashboard.subscribeOrManageBilling') %></a>
        <% } %>
      </div>
    </aside>
  </div>

  <div id="dash-modal-research" class="account-modal-overlay" hidden>
    <div class="account-modal-overlay__backdrop dash-modal-backdrop" tabindex="-1" aria-hidden="true"></div>
    <div class="account-modal-overlay__panel dash-modal-panel" role="dialog" aria-modal="true" aria-labelledby="dash-modal-research-title">
      <h3 id="dash-modal-research-title" class="dash-modal-title-blue"><%= t('dashboard.modalResearchTitle') %></h3>
      <p class="dash-modal-muted"><%= t('dashboard.modalResearchLeadBefore') %> <a href="<%= foundryHref %>" class="dash-modal-link-foundry"><%= t('dashboard.foundryLink') %></a><%= t('dashboard.modalResearchLeadAfter') %></p>
      <form id="dash-form-research" class="dash-modal-form">
        <label class="dash-modal-label"><%= t('dashboard.researchTopic') %></label>
        <input type="text" name="researchTopic" class="dash-modal-input" required maxlength="500" />
        <label class="dash-modal-label"><%= t('dashboard.keywords') %></label>
        <input type="text" name="keywords" class="dash-modal-input" maxlength="500" />
        <label class="dash-modal-label"><%= t('dashboard.notes') %></label>
        <textarea name="notes" class="dash-modal-textarea" rows="4" maxlength="20000"></textarea>
        <p id="dash-research-form-msg" class="dash-modal-msg" hidden></p>
        <div class="account-modal-overlay__actions">
          <button type="submit" class="account-modal-overlay__btn account-modal-overlay__btn--confirm-mint"><%= t('client.common.save') %></button>
          <button type="button" class="account-modal-overlay__btn account-modal-overlay__btn--secondary dash-modal-close"><%= t('client.common.close') %></button>
        </div>
      </form>
    </div>
  </div>

  <div id="dash-modal-published" class="account-modal-overlay" hidden>
    <div class="account-modal-overlay__backdrop dash-modal-backdrop" tabindex="-1" aria-hidden="true"></div>
    <div class="account-modal-overlay__panel dash-modal-panel" role="dialog" aria-modal="true" aria-labelledby="dash-modal-published-title">
      <h3 id="dash-modal-published-title" class="dash-modal-title-blue"><%= t('dashboard.modalPublishedTitle') %></h3>
      <p class="dash-modal-muted"><%= t('dashboard.modalPublishedLead') %></p>
      <form id="dash-form-published" class="dash-modal-form">
        <label class="dash-modal-label"><%= t('dashboard.pubTitle') %></label>
        <input type="text" name="title" class="dash-modal-input" required maxlength="500" />
        <label class="dash-modal-label"><%= t('dashboard.datePublished') %></label>
        <input type="text" name="datePublished" class="dash-modal-input" maxlength="100" placeholder="<%= t('dashboard.placeholderDatePublished') %>" />
        <label class="dash-modal-label"><%= t('dashboard.wherePublished') %></label>
        <input type="text" name="wherePublished" class="dash-modal-input" maxlength="500" />
        <label class="dash-modal-label"><%= t('dashboard.link') %></label>
        <input type="url" name="link" class="dash-modal-input" maxlength="1000" placeholder="<%= t('dashboard.placeholderLink') %>" />
        <p id="dash-published-form-msg" class="dash-modal-msg" hidden></p>
        <div class="account-modal-overlay__actions">
          <button type="submit" class="account-modal-overlay__btn account-modal-overlay__btn--confirm-mint"><%= t('client.common.save') %></button>
          <button type="button" class="account-modal-overlay__btn account-modal-overlay__btn--secondary dash-modal-close"><%= t('client.common.close') %></button>
        </div>
      </form>
    </div>
  </div>

  <div id="dash-modal-cancel-project" class="account-modal-overlay" hidden>
    <div class="account-modal-overlay__backdrop dash-modal-backdrop" tabindex="-1" aria-hidden="true"></div>
    <div class="account-modal-overlay__panel dash-modal-panel dash-modal-panel--narrow" role="dialog" aria-modal="true" aria-labelledby="dash-modal-cancel-title">
      <h3 id="dash-modal-cancel-title" class="account-modal-overlay__title"><%= t('dashboard.cancelProjectTitle') %></h3>
      <div class="account-modal-overlay__actions dash-cancel-actions">
        <button type="button" class="account-modal-overlay__btn account-modal-overlay__btn--keep" id="dash-cancel-project-dismiss"><%= t('dashboard.cancelAction') %></button>
        <button type="button" class="account-modal-overlay__btn account-modal-overlay__btn--confirm-cancel" id="dash-cancel-project-confirm"><%= t('dashboard.yesCancelProject') %></button>
      </div>
    </div>
  </div>

  <script>
    window.__DASHBOARD__ = <%- typeof dashboardClientJson !== 'undefined' ? dashboardClientJson : '{}' %>;
  </script>
  <script src="/js/dashboard.js" defer></script>
</body>
</html>
