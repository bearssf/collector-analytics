<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Training walkthrough (admin)</title>
  <style>
    body { font-family: system-ui, sans-serif; margin: 0; padding: 1.25rem; background: #0f1419; color: #e6edf3; line-height: 1.45; }
    h1 { font-size: 1.15rem; margin: 0 0 0.5rem; }
    p.hint { font-size: 0.82rem; color: #8b949e; margin: 0 0 1rem; max-width: 40rem; }
    label { display: block; font-size: 0.75rem; color: #8b949e; margin: 0.5rem 0 0.2rem; }
    input, textarea, select { width: 100%; max-width: 36rem; box-sizing: border-box; padding: 0.4rem 0.5rem; border-radius: 6px; border: 1px solid #30363d; background: #161b22; color: #e6edf3; font-size: 0.88rem; }
    textarea { min-height: 4rem; resize: vertical; }
    table { border-collapse: collapse; width: 100%; max-width: 56rem; font-size: 0.8rem; margin-top: 1.25rem; }
    th, td { border: 1px solid #30363d; padding: 0.45rem 0.5rem; text-align: left; vertical-align: top; }
    th { background: #161b22; color: #8b949e; font-weight: 600; }
    .mono { font-family: ui-monospace, monospace; font-size: 0.76rem; word-break: break-all; }
    button { margin-top: 0.65rem; padding: 0.45rem 0.9rem; border-radius: 6px; border: none; font-weight: 600; cursor: pointer; font-size: 0.82rem; }
    .btn-primary { background: #2f80ee; color: #fff; }
    .btn-primary:hover { background: #256fd0; }
    .btn-danger { background: #da3633; color: #fff; margin-left: 0.35rem; }
    .btn-danger:hover { background: #b62324; }
    #admin-train-status { font-size: 0.82rem; margin-left: 0.75rem; min-height: 1.2rem; display: inline-block; }
    #admin-train-status.err { color: #f85149; }
    #admin-train-status.ok { color: #3fb950; }
    .form-block { max-width: 36rem; padding: 1rem; border: 1px dashed #30363d; border-radius: 10px; margin-top: 1rem; }
    .train-anchors-wrap { max-width: 56rem; margin-bottom: 1.25rem; }
    .train-anchors-wrap > .hint { margin-bottom: 0.75rem; }
    .train-page-anchors { margin: 0 0 1rem; padding-bottom: 0.85rem; border-bottom: 1px solid #21262d; }
    .train-page-anchors:last-child { border-bottom: none; }
    .train-page-anchors h2 { font-weight: 600; color: #e6edf3; }
    .train-slug { color: #8b949e; font-weight: 400; }
    .train-page-anchors ul { margin: 0.35rem 0 0; padding-left: 1.15rem; }
    .train-page-anchors li { margin: 0.25rem 0; color: #c9d1d9; }
    .train-empty { margin: 0.25rem 0 0; font-size: 0.8rem; color: #6e7681; }
    button.train-move-btn { margin-top: 0; padding: 0.28rem 0.5rem; font-size: 0.72rem; font-weight: 600; background: #21262d; color: #e6edf3; border: 1px solid #30363d; border-radius: 6px; cursor: pointer; }
    button.train-move-btn:hover:not(:disabled) { background: #30363d; }
    button.train-move-btn:disabled { opacity: 0.35; cursor: not-allowed; }
    .train-move-cell { white-space: nowrap; vertical-align: middle; }
    .train-move-cell .train-move-btn + .train-move-btn { margin-left: 0.35rem; }
  </style>
</head>
<body>
  <h1>Training walkthrough steps</h1>
  <p class="hint">Use <code>?token=…</code> with <code>ADMIN_TRAINING_EDITOR_TOKEN</code>. Each step needs a page, a CSS selector (see the list below), body text, and sort order.</p>
  <script id="admin-train-json" type="application/json"><%- trainingAdminJson %></script>
  <div id="admin-train-root"></div>
  <script src="/js/admin-training-walkthrough.js" defer></script>
</body>
</html>
