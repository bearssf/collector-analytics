<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>CollectorAnalytics</title>
  <style>
    * { box-sizing: border-box; }
    body {
      margin: 0;
      min-height: 100vh;
      background: #000;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
      color: #fff;
    }
    .header {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      padding: 1rem 1.5rem;
      display: flex;
      justify-content: flex-end;
      align-items: center;
      z-index: 10;
    }
    .header .welcome {
      color: #fff;
      font-size: 1rem;
    }
    .login-box {
      background: #111;
      border: 1px solid #333;
      border-radius: 8px;
      padding: 1rem 1.25rem;
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.5rem 1rem;
      max-width: 360px;
    }
    .login-box input {
      padding: 0.5rem 0.75rem;
      border: 1px solid #444;
      border-radius: 4px;
      background: #222;
      color: #fff;
      font-size: 0.9rem;
      width: 140px;
    }
    .login-box input::placeholder { color: #888; }
    .login-box button {
      padding: 0.5rem 1rem;
      background: #1a5fb4;
      color: #fff;
      border: none;
      border-radius: 4px;
      cursor: pointer;
      font-size: 0.9rem;
    }
    .login-box button:hover { background: #3584e4; }
    .login-box a {
      color: #f0c674;
      font-size: 0.85rem;
      text-decoration: none;
      width: 100%;
    }
    .login-box a:hover { text-decoration: underline; }
    .main {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 5rem 1rem 2rem;
    }
    .main img {
      max-width: 100%;
      height: auto;
      display: block;
    }
    .error-msg {
      color: #e06c75;
      font-size: 0.85rem;
      margin-top: 0.25rem;
    }
  </style>
</head>
<body>
  <header class="header">
    <% if (user) { %>
      <span class="welcome">Welcome, <%= user.firstName %>.</span>
      <form action="/logout" method="post" style="margin-left: 1rem;">
        <button type="submit">Sign out</button>
      </form>
    <% } else { %>
      <div class="login-box">
        <form action="/login" method="post" style="display: contents;">
          <input type="email" name="email" placeholder="Email" required autocomplete="email" />
          <input type="password" name="password" placeholder="Password" required autocomplete="current-password" />
          <button type="submit">Sign in</button>
        </form>
        <% if (typeof error !== 'undefined' && error === 'missing') { %>
          <span class="error-msg">Please enter email and password.</span>
        <% } else if (typeof error !== 'undefined' && error === 'invalid') { %>
          <span class="error-msg">Invalid email or password.</span>
        <% } else if (typeof error !== 'undefined' && error === 'server') { %>
          <span class="error-msg">Something went wrong. Try again.</span>
        <% } %>
        <a href="/register">Create an account</a>
      </div>
    <% } %>
  </header>

  <main class="main">
    <img src="/logo.png" alt="CollectorAnalytics - Know what collectors actually paid" />
  </main>
</body>
</html>
