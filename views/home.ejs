<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AcademiqForge</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
  <style>
    * { box-sizing: border-box; }
    body {
      margin: 0;
      min-height: 100vh;
      background: #000;
      font-family: 'Libre Baskerville', Georgia, 'Times New Roman', serif;
      color: #fff;
    }
    .header {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      padding: 1rem 1.5rem;
      display: flex;
      justify-content: flex-end;
      align-items: flex-start;
      z-index: 10;
    }
    .welcome-box {
      background: #0d0d0d;
      border: 1px solid #2a2a2a;
      border-radius: 8px;
      padding: 0.65rem 1rem;
      display: flex;
      align-items: center;
      gap: 1rem;
      flex-wrap: wrap;
      justify-content: flex-end;
    }
    .header .welcome {
      color: #e8e8e8;
      font-size: 0.95rem;
      font-weight: 400;
    }
    .sign-out {
      color: #56b4e9;
      font-size: 0.85rem;
      text-decoration: none;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    }
    .sign-out:hover { color: #8ecfef; text-decoration: underline; }
    .login-box {
      background: #0d0d0d;
      border: 1px solid #2a2a2a;
      border-radius: 8px;
      padding: 1rem 1.25rem;
      display: flex;
      flex-direction: column;
      align-items: stretch;
      gap: 0.65rem;
      max-width: 340px;
    }
    .login-row {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.5rem 0.75rem;
    }
    .login-box input {
      padding: 0.5rem 0.65rem;
      border: 1px solid #3a3a3a;
      border-radius: 4px;
      background: #161616;
      color: #fff;
      font-size: 0.88rem;
      width: 130px;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    }
    .login-box input::placeholder { color: #888; }
    .login-box button {
      padding: 0.5rem 0.9rem;
      background: #1a6cad;
      color: #fff;
      border: none;
      border-radius: 4px;
      cursor: pointer;
      font-size: 0.88rem;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    }
    .login-box button:hover { background: #3584e4; }
    .login-box .create-link {
      color: #56b4e9;
      font-size: 0.82rem;
      text-decoration: none;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      text-align: center;
    }
    .login-box .create-link:hover { text-decoration: underline; }
    .main {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 5.5rem 1.5rem 2rem;
    }
    .main img {
      max-width: min(520px, 100%);
      height: auto;
      display: block;
    }
    .error-msg {
      color: #e07a7a;
      font-size: 0.8rem;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    }
  </style>
</head>
<body>
  <header class="header">
    <% if (user) { %>
      <div class="welcome-box">
        <span class="welcome">Welcome, <%= user.firstName %></span>
        <a href="#" onclick="document.getElementById('logout-form').submit(); return false;" class="sign-out">Sign out</a>
      </div>
      <form id="logout-form" action="/logout" method="post" style="display: none;"><button type="submit">Sign out</button></form>
    <% } else { %>
      <div class="login-box">
        <form action="/login" method="post" class="login-row">
          <input type="email" name="email" placeholder="Email" required autocomplete="email" />
          <input type="password" name="password" placeholder="Password" required autocomplete="current-password" />
          <button type="submit">Sign in</button>
        </form>
        <% if (typeof error !== 'undefined' && error === 'missing') { %>
          <span class="error-msg">Please enter email and password.</span>
        <% } else if (typeof error !== 'undefined' && error === 'invalid') { %>
          <span class="error-msg">Invalid email or password.</span>
        <% } else if (typeof error !== 'undefined' && error === 'server') { %>
          <span class="error-msg">Something went wrong. Try again.</span>
        <% } %>
        <a href="/register" class="create-link">Create an account</a>
      </div>
    <% } %>
  </header>

  <main class="main">
    <img src="/logo.png" alt="AcademiqForge" />
  </main>
</body>
</html>
