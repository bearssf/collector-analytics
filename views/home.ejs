<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AcademiqForge</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/academiq.css" />
</head>
<body class="home-page">
  <%
    const pillars = [
      { title: "Shaped by Experience", body: "Built from real doctoral workflows so the path from concept to completed paper feels guided, not improvised." },
      { title: "Hardened for Usability", body: "A calm, minimal interface that removes friction and keeps your attention on research, writing, and momentum." },
      { title: "Polished for Completion", body: "Designed to carry you from first idea to finished paper with structure, feedback, and progress built in." },
    ];
  %>
  <div class="shell">
    <%- include('partials/topnav', { user: user, navActive: '' }) %>

    <section class="hero">
      <div class="hero-glow"></div>
      <div class="hero-grid">
        <div>
          <div class="badge">The research operating system</div>
          <h1>From idea to finished paper, with less friction and more rigor.</h1>
          <p class="lead">Shaped by experience, hardened for usability, and polished to carry researchers from scattered notes to structured, defensible writing.</p>
          <div class="hero-actions">
            <a href="/app/dashboard" class="btn btn-blue">Start Forging</a>
            <a href="<%= user ? '/app/account' : '/register' %>" class="btn btn-trial">Claim Your 7 Day Free Trial</a>
          </div>
          <div class="meta">
            <div>Managed Writing Environment</div><div class="dot"></div><div>Effectively Manage Sources and Notes</div><div class="dot"></div><div>Feedback and Suggestions on Writing from the Latest AI Models</div>
          </div>
        </div>

        <div class="pillars-col" aria-label="Highlights">
          <% pillars.forEach(function (pillar) { %>
            <article class="card">
              <div class="pillar-card-head">
                <div class="ico" aria-hidden="true"></div>
                <h3><%= pillar.title %></h3>
              </div>
              <p><%= pillar.body %></p>
            </article>
          <% }) %>
        </div>
      </div>
    </section>
  </div>

  <%- include('partials/signin-modal', { user: user, error: error, returnTo: typeof returnTo !== 'undefined' ? returnTo : '/', openSignin: typeof openSignin !== 'undefined' && openSignin }) %>
</body>
</html>
