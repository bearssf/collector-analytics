<!DOCTYPE html>
<html lang="<%= typeof htmlLang !== 'undefined' ? htmlLang : 'en' %>" dir="<%= typeof textDir !== 'undefined' ? textDir : 'ltr' %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= t('forgotPassword.pageTitle') %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/academiq.css" />
</head>
<body class="home-page">
  <div class="shell">
    <%- include('partials/topnav', { user: typeof user !== 'undefined' ? user : null, navActive: '' }) %>
    <div class="auth-page-shell">
      <div class="auth-page-card">
        <h1><%= t('forgotPassword.h1') %></h1>
        <% if (typeof sent !== 'undefined' && sent) { %>
          <p class="hint-msg auth-sent-msg"><%= t('forgotPassword.sentBody') %></p>
          <p class="auth-page-meta"><a href="/"><%= t('forgotPassword.backHome') %></a></p>
        <% } else { %>
          <% if (typeof error !== 'undefined' && error === 'missing') { %>
            <p class="error-msg"><%= t('forgotPassword.errorMissing') %></p>
          <% } else if (typeof error !== 'undefined' && error === 'config') { %>
            <p class="error-msg"><%= t('forgotPassword.errorConfig') %></p>
          <% } else if (typeof error !== 'undefined' && error === 'send') { %>
            <p class="error-msg"><%= t('forgotPassword.errorSend') %></p>
          <% } else if (typeof error !== 'undefined' && error === 'mail') { %>
            <p class="error-msg"><%= t('forgotPassword.errorMail') %></p>
          <% } else if (typeof error !== 'undefined' && error === 'server') { %>
            <p class="error-msg"><%= t('forgotPassword.errorServer') %></p>
          <% } %>
          <form action="/forgot-password" method="post">
            <div class="field">
              <label for="fp-email"><%= t('auth.email') %></label>
              <input type="email" id="fp-email" name="email" required autocomplete="email" value="<%= typeof prefillEmail !== 'undefined' ? prefillEmail : '' %>" />
            </div>
            <div class="btn-row">
              <button type="submit" class="btn btn-blue"><%= t('forgotPassword.submit') %></button>
              <a href="/"><%= t('forgotPassword.cancel') %></a>
            </div>
          </form>
        <% } %>
      </div>
    </div>
  </div>
</body>
</html>
