<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Forgot password – AcademiqForge</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/academiq.css" />
</head>
<body class="home-page">
  <div class="shell">
    <%- include('partials/topnav', { user: typeof user !== 'undefined' ? user : null, navActive: '' }) %>
    <div class="auth-page-shell">
      <div class="auth-page-card">
        <h1>Reset your password</h1>
        <% if (typeof sent !== 'undefined' && sent) { %>
          <p class="success-msg">If an account exists for that email address, we sent a link to reset your password. Check your inbox.</p>
          <p class="auth-page-meta"><a href="/">Back to home</a></p>
        <% } else { %>
          <% if (typeof error !== 'undefined' && error === 'missing') { %>
            <p class="error-msg">Enter your email address.</p>
          <% } else if (typeof error !== 'undefined' && error === 'config') { %>
            <p class="error-msg">Password reset is not fully configured on this server (<code>PUBLIC_BASE_URL</code>). Contact support.</p>
          <% } else if (typeof error !== 'undefined' && error === 'send') { %>
            <p class="error-msg">We could not send the email. Try again later or contact support.</p>
          <% } else if (typeof error !== 'undefined' && error === 'mail') { %>
            <p class="error-msg">Email is not configured on this server. Set <code>SMTP_HOST</code>, <code>MAIL_FROM</code>, and related variables, or contact your administrator.</p>
          <% } else if (typeof error !== 'undefined' && error === 'server') { %>
            <p class="error-msg">Something went wrong. Try again.</p>
          <% } %>
          <% if (typeof mailConfigured !== 'undefined' && !mailConfigured && !error) { %>
            <p class="hint-msg">Note: outbound email may not be configured on this environment. If you do not receive a message, contact support.</p>
          <% } %>
          <form action="/forgot-password" method="post">
            <div class="field">
              <label for="fp-email">Email</label>
              <input type="email" id="fp-email" name="email" required autocomplete="email" value="<%= typeof prefillEmail !== 'undefined' ? prefillEmail : '' %>" />
            </div>
            <div class="btn-row">
              <button type="submit" class="btn btn-blue">Send reset link</button>
              <a href="/">Cancel</a>
            </div>
          </form>
        <% } %>
      </div>
    </div>
  </div>
</body>
</html>
