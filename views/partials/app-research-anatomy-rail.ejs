<%#
  Research Anatomy — right column (20% review / 80% assessment table).
%>
<aside class="app-insight app-research-anatomy-rail" aria-label="<%= t('workspace.researchAnatomy.railAria') %>">
  <div class="ra-rail-shell">
    <div class="ra-rail-shell__top">
      <div class="insight-h ra-rail-shell__heading"><%= t('workspace.researchAnatomy.forgedReviewHeading') %></div>
      <button type="button" class="ra-review-btn" id="ra-initiate-review" data-state="init">
        <%= t('workspace.researchAnatomy.btnInitiate') %>
      </button>
      <p class="ra-review-status" id="ra-review-status" hidden></p>
      <p class="ra-cooldown-msg" id="ra-cooldown-msg" hidden></p>
    </div>
    <div class="ra-rail-shell__bottom">
      <div class="insight-h ra-rail-shell__heading"><%= t('workspace.researchAnatomy.forgedAssessmentHeading') %></div>
      <p class="ra-assessment-desc"><%= t('workspace.researchAnatomy.forgedAssessmentDesc') %></p>
      <div class="ra-assessment-table-wrap">
        <table class="ra-assessment-table" id="ra-assessment-table" aria-label="<%= t('workspace.researchAnatomy.tableAria') %>">
          <thead>
            <tr><th><%= t('workspace.researchAnatomy.colComponent') %></th><th><%= t('workspace.researchAnatomy.colScore') %></th></tr>
          </thead>
          <tbody id="ra-assessment-tbody">
          </tbody>
        </table>
        <p class="ra-assessment-empty" id="ra-assessment-empty"><%= t('workspace.researchAnatomy.tableEmpty') %></p>
      </div>
    </div>
  </div>

  <div class="ra-modal" id="ra-modal-insufficient" hidden role="dialog" aria-modal="true" aria-labelledby="ra-modal-insufficient-title">
    <div class="ra-modal__backdrop" data-ra-modal-close></div>
    <div class="ra-modal__panel">
      <p class="ra-modal__text" id="ra-modal-insufficient-title"><%= t('workspace.researchAnatomy.modalInsufficient') %></p>
      <button type="button" class="ra-modal__btn ra-modal__btn--primary" id="ra-modal-insufficient-ok"><%= t('workspace.researchAnatomy.modalBtnOk') %></button>
    </div>
  </div>

  <div class="ra-modal" id="ra-modal-time" hidden role="dialog" aria-modal="true" aria-labelledby="ra-modal-time-title">
    <div class="ra-modal__backdrop" data-ra-modal-close></div>
    <div class="ra-modal__panel">
      <p class="ra-modal__text" id="ra-modal-time-title"><%= t('workspace.researchAnatomy.modalTimeBody') %></p>
      <div class="ra-modal__actions">
        <button type="button" class="ra-modal__btn" id="ra-modal-time-cancel"><%= t('workspace.researchAnatomy.modalBtnCancel') %></button>
        <button type="button" class="ra-modal__btn ra-modal__btn--primary" id="ra-modal-time-confirm"><%= t('workspace.researchAnatomy.modalBtnContinue') %></button>
      </div>
    </div>
  </div>
</aside>
