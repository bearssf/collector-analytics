<%#
  Anvil-only right column: feedback & suggestions (top), citations (bottom).
  Feedback: public/js/anvil.js (GET/PATCH suggestions). Citations: GET /api/projects/:id/sources.
%>
<aside class="app-insight app-anvil-rail" aria-label="Writing feedback and citations">
  <div class="app-anvil-rail__stack">
    <section class="app-anvil-rail__pane" aria-labelledby="anvil-rail-feedback-h">
      <div id="anvil-rail-feedback-h" class="insight-h">Feedback & suggestions</div>
      <div id="anvil-feedback-pane" class="app-anvil-rail__scroll">
        <div id="anvil-feedback-mount" class="anvil-feedback-mount" aria-live="polite">
          <p class="anvil-feedback-placeholder">Loading feedback…</p>
        </div>
      </div>
    </section>
    <section class="app-anvil-rail__pane" aria-labelledby="anvil-rail-citations-h">
      <div id="anvil-rail-citations-h" class="insight-h">Citations</div>
      <div id="anvil-citations-pane" class="app-anvil-rail__scroll">
        <div id="anvil-citations-mount" class="anvil-citations-mount" aria-live="polite">
          <p class="anvil-citations-placeholder">Loading sources…</p>
        </div>
      </div>
    </section>
  </div>
</aside>
