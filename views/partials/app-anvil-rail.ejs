<%#
  The Anvil: structured AI feedback (client-side + /review-structured).
%>
<aside class="app-insight app-anvil-rail" aria-label="AI feedback">
  <div class="app-anvil-rail__inner">
    <div class="insight-h">AI feedback</div>
    <p class="app-anvil-rail__hint">Anchored suggestions from the model. Apply updates the draft; items that no longer match the text are removed. New analysis adds suggestions above older ones.</p>
    <div id="anvil-feedback-mount" class="app-anvil-rail__scroll" aria-live="polite">
      <p class="anvil2-feedback-placeholder">Load a section to see feedback after you pause typing.</p>
    </div>
  </div>
</aside>
