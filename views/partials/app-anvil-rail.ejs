<%#
  The Anvil: structured AI feedback + citations placeholder.
%>
<aside class="app-insight app-anvil-rail" aria-label="Feedback and suggestions">
  <div class="app-anvil-rail__inner">
    <div class="app-anvil-rail__top">
      <div class="insight-h insight-h--feedback">Feedback &amp; Suggestions <button type="button" class="anvil-refresh-feedback-btn" id="anvil-refresh-feedback" title="Refresh feedback &amp; suggestions">&#x21bb;</button></div>
      <div id="anvil-feedback-mount" class="app-anvil-rail__scroll" aria-live="polite">
        <p class="anvil2-feedback-placeholder">Feedback and suggestions will appear here as you make progress with your writing.</p>
      </div>
    </div>
    <div class="app-anvil-rail__bottom">
      <div class="insight-h insight-h--citations">Sources <button type="button" class="anvil-add-source-btn" id="anvil-add-source-btn">+ Add a Source</button></div>
      <div id="anvil-citations-mount" class="app-anvil-rail__scroll">
        <p class="app-anvil-rail__citations-placeholder">Select a section to view tagged sources.</p>
      </div>
    </div>
  </div>
</aside>
