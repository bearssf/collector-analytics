<%#
  Anvil2 (beta): structured anchor-based feedback (client-side store + /review-structured).
%>
<aside class="app-insight app-anvil2-rail" aria-label="AI feedback (beta)">
  <div class="app-anvil2-rail__inner">
    <div class="insight-h">AI feedback (beta)</div>
    <p class="app-anvil2-rail__hint">Anchored suggestions from the model. Apply updates the draft; items that no longer match the text are removed. New analysis adds suggestions above older ones.</p>
    <div id="anvil2-feedback-mount" class="app-anvil2-rail__scroll" aria-live="polite">
      <p class="anvil2-feedback-placeholder">Load a section to see feedback after you pause typing.</p>
    </div>
  </div>
</aside>
