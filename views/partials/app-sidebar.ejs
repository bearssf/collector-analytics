<% var na = typeof navActive !== 'undefined' ? navActive : ''; %>
<% var projects = typeof projects !== 'undefined' && projects ? projects : []; %>
<% function truncateProjectTitle(name) {
  var s = String(name == null ? '' : name);
  if (s.length <= 25) return s;
  return s.slice(0, 25) + '...';
} %>
<% function localizedSectionTitle(sec) {
  return typeof sectionLabel !== 'undefined' ? sectionLabel(sec) : (function () {
    var slug = sec.slug != null ? String(sec.slug).trim() : '';
    if (!slug) return sec.title;
    var key = 'sectionLabels.' + slug.replace(/-/g, '_');
    var tr = t(key);
    if (tr && tr !== key) return tr;
    return sec.title;
  })();
} %>
<% var cur = typeof currentProjectId !== 'undefined' && currentProjectId != null ? currentProjectId : null; %>
<% function __sidebarProjectCanceled(p) {
  return String(p && p.status || '').toLowerCase() === 'canceled';
} %>
<% var firstOpenProject = null;
  for (var _si = 0; _si < projects.length; _si++) {
    if (!__sidebarProjectCanceled(projects[_si])) { firstOpenProject = projects[_si]; break; }
  }
%>
<% var effectivePid = cur != null ? String(cur) : (firstOpenProject ? String(firstOpenProject.id) : ''); %>
<% var slug = typeof workspaceSlug !== 'undefined' ? workspaceSlug : ''; %>
<% var access = typeof appAccess !== 'undefined' && appAccess ? appAccess : { foundryUnlocked: false, trialing: false, paid: false }; %>
<%
  var currentProject = null;
  if (effectivePid) {
    for (var _i = 0; _i < projects.length; _i++) {
      if (String(projects[_i].id) === effectivePid) { currentProject = projects[_i]; break; }
    }
  }
  if (!currentProject && firstOpenProject) currentProject = firstOpenProject;
%>
<aside class="app-sidebar" aria-label="Workspace navigation">
  <a href="/" class="app-sidebar-brand" title="Marketing home">
    <div class="mark"><div class="dot"></div></div>
    <div class="word"><span class="a">Academiq</span><span>Forge</span></div>
  </a>

  <div class="app-nav-section">
    <div class="app-nav-label"><%= t('sidebar.workspace') %></div>
    <nav class="app-nav">
      <a href="/app/account" id="tw-nav-account" class="<%= na === 'account' ? 'active' : '' %>"><%= t('sidebar.account') %></a>
      <a href="/app/dashboard" id="tw-nav-portfolio" class="<%= na === 'dashboard' ? 'active' : '' %>"><%= t('sidebar.portfolio') %></a>
      <% if (access.foundryUnlocked) { %>
        <a href="<%= effectivePid ? '/app/project/' + effectivePid + '/foundry' : '#' %>" id="tw-nav-foundry" class="<%= slug === 'foundry' ? 'active' : '' %>"><%= t('sidebar.foundry') %></a>
      <% } else { %>
        <a href="<%= effectivePid ? '/app/project/' + effectivePid + '/foundry' : '#' %>" id="tw-nav-foundry" class="<%= slug === 'foundry' ? 'active' : '' %> locked"><%= t('sidebar.foundry') %> <span class="badge-pay"><%= t('sidebar.foundryPaid') %></span></a>
      <% } %>
    </nav>
  </div>

  <div class="app-nav-section">
    <div class="app-nav-label"><%= t('sidebar.project') %></div>
    <% if (!currentProject) { %>
      <p class="app-sidebar-muted"><%= t('project.noProjects') %><br><a href="/app/projects/new"><%= t('project.forgeProject') %></a></p>
    <% } else { %>
      <a href="/app/project/<%= effectivePid %>/settings" class="app-sidebar-project-name" title="<%= currentProject.name %>"><%= truncateProjectTitle(currentProject.name) %></a>
      <nav class="app-nav">
        <% var hasActiveSection = typeof anvilSectionId !== 'undefined' && anvilSectionId != null; %>
        <a href="/app/project/<%= effectivePid %>/anvil<%= (typeof anvilSections !== 'undefined' && anvilSections.length) ? ('?section=' + anvilSections[0].id) : '' %>" id="tw-nav-anvil" class="<%= slug === 'anvil' && !hasActiveSection ? 'active' : '' %>"><%= t('sidebar.anvil') %></a>
        <% if (typeof anvilSections !== 'undefined' && anvilSections.length && slug !== 'foundry') { %>
        <nav class="app-nav app-nav--anvil-sections" aria-label="<%= t('client.anvil.sectionDraftsAria') %>">
          <% anvilSections.forEach(function (sec) { %>
            <a href="/app/project/<%= effectivePid %>/anvil?section=<%= sec.id %>" class="<%= hasActiveSection && Number(anvilSectionId) === Number(sec.id) ? 'active' : '' %>"><%= localizedSectionTitle(sec) %></a>
          <% }); %>
        </nav>
        <% } %>
        <a href="/app/project/<%= effectivePid %>/crucible" id="tw-nav-crucible" class="<%= slug === 'crucible' ? 'active' : '' %>"><%= t('sidebar.crucible') %></a>
        <a href="/app/project/<%= effectivePid %>/framework" id="tw-nav-framework" class="<%= slug === 'framework' ? 'active' : '' %>"><%= t('sidebar.framework') %></a>
      </nav>
    <% } %>
  </div>

  <% if (typeof showAdminNav !== 'undefined' && showAdminNav) { %>
  <div class="app-nav-section">
    <div class="app-nav-label"><%= t('sidebar.admin') %></div>
    <nav class="app-nav">
      <% if (typeof adminProjectTemplatesHref !== 'undefined' && adminProjectTemplatesHref) { %>
        <a href="<%= adminProjectTemplatesHref %>"><%= t('sidebar.adminTemplates') %></a>
      <% } %>
      <% if (typeof adminTrainingHref !== 'undefined' && adminTrainingHref) { %>
        <a href="<%= adminTrainingHref %>"><%= t('sidebar.adminTraining') %></a>
      <% } %>
      <% if (typeof adminResearchAnatomyHref !== 'undefined' && adminResearchAnatomyHref) { %>
        <a href="<%= adminResearchAnatomyHref %>"><%= t('sidebar.adminResearchAnatomy') %></a>
      <% } %>
      <% if (typeof adminResearchStage1Href !== 'undefined' && adminResearchStage1Href) { %>
        <a href="<%= adminResearchStage1Href %>"><%= t('sidebar.adminResearchStage1') %></a>
      <% } %>
      <% if (typeof adminResearchStage1TimingHref !== 'undefined' && adminResearchStage1TimingHref) { %>
        <a href="<%= adminResearchStage1TimingHref %>"><%= t('sidebar.adminResearchStage1Timing') %></a>
      <% } %>
    </nav>
  </div>
  <% } %>

  <div class="app-sidebar-footer">
    <a href="/" class="app-sidebar-home" id="tw-sidebar-home"><%= t('sidebar.home') %></a>
    <% if (typeof trainingReplayAvailable !== 'undefined' && trainingReplayAvailable && typeof trainingClientPayload !== 'undefined' && trainingClientPayload && trainingClientPayload.pageSlug) { %>
    <button type="button" class="app-sidebar-training" id="tw-sidebar-page-tour" data-page-slug="<%= trainingClientPayload.pageSlug %>"><%= t('sidebar.pageTour') %></button>
    <% } %>
  </div>
</aside>
