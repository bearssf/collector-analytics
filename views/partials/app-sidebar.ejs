<% var na = typeof navActive !== 'undefined' ? navActive : ''; %>
<% var projects = typeof projects !== 'undefined' && projects ? projects : []; %>
<% function truncateProjectTitle(name) {
  var s = String(name == null ? '' : name);
  if (s.length <= 25) return s;
  return s.slice(0, 25) + '...';
} %>
<% var cur = typeof currentProjectId !== 'undefined' && currentProjectId != null ? currentProjectId : null; %>
<% var effectivePid = cur != null ? String(cur) : (projects[0] ? String(projects[0].id) : ''); %>
<% var slug = typeof workspaceSlug !== 'undefined' ? workspaceSlug : ''; %>
<% var access = typeof appAccess !== 'undefined' && appAccess ? appAccess : { foundryUnlocked: false, trialing: false, paid: false }; %>
<aside class="app-sidebar" aria-label="Workspace navigation">
  <a href="/" class="app-sidebar-brand" title="Marketing home">
    <div class="mark"><div class="dot"></div></div>
    <div class="word"><span class="a">Academiq</span><span>Forge</span></div>
  </a>

  <div class="app-nav-section">
    <div class="app-nav-label">Workspace</div>
    <nav class="app-nav">
      <a href="/app/dashboard" class="<%= na === 'dashboard' ? 'active' : '' %>">Portfolio dashboard</a>
      <a href="/app/account" class="<%= na === 'account' ? 'active' : '' %>">Account</a>
    </nav>
  </div>

  <div class="app-nav-section">
    <div class="app-nav-label">Project</div>
    <% if (projects.length === 0) { %>
      <p class="app-sidebar-muted">No projects yet.<br><a href="/app/projects/new">Forge a project</a></p>
    <% } else { %>
      <% if (projects.length > 1) { %>
        <nav class="app-nav app-project-picker" aria-label="Switch project">
          <% projects.forEach(function(p) { %>
            <a href="/app/project/<%= p.id %>/anvil" class="<%= (cur == p.id && na === 'workspace') ? 'active' : '' %>"><%= p.name %></a>
          <% }); %>
        </nav>
      <% } else { %>
        <span class="app-sidebar-project-name" title="<%= projects[0].name %>"><%= truncateProjectTitle(projects[0].name) %></span>
      <% } %>
      <% if (effectivePid) { %>
        <nav class="app-nav">
          <a href="/app/project/<%= effectivePid %>/settings" class="<%= typeof workspaceSlug !== 'undefined' && workspaceSlug === 'settings' ? 'active' : '' %>">Project settings</a>
          <a href="/app/project/<%= effectivePid %>/anvil<%= (typeof anvilSections !== 'undefined' && anvilSections.length) ? ('?section=' + anvilSections[0].id) : '' %>" class="<%= slug === 'anvil' ? 'active' : '' %>">The Anvil</a>
          <% if (typeof anvilSections !== 'undefined' && anvilSections.length && slug === 'anvil') { %>
          <nav class="app-nav app-nav--anvil-sections" aria-label="Section drafts">
            <% anvilSections.forEach(function (sec) { %>
              <a href="/app/project/<%= effectivePid %>/<%= slug %>?section=<%= sec.id %>" class="<%= typeof anvilSectionId !== 'undefined' && anvilSectionId != null && Number(anvilSectionId) === Number(sec.id) ? 'active' : '' %>"><%= sec.title %></a>
            <% }); %>
          </nav>
          <% } %>
          <a href="/app/project/<%= effectivePid %>/crucible" class="<%= slug === 'crucible' ? 'active' : '' %>">The Crucible</a>
          <% if (access.foundryUnlocked) { %>
            <a href="/app/project/<%= effectivePid %>/foundry" class="<%= slug === 'foundry' ? 'active' : '' %>">The Foundry</a>
          <% } else { %>
            <a href="/app/project/<%= effectivePid %>/foundry" class="<%= slug === 'foundry' ? 'active' : '' %> locked">The Foundry <span class="badge-pay">Paid</span></a>
          <% } %>
          <a href="/app/project/<%= effectivePid %>/framework" class="<%= slug === 'framework' ? 'active' : '' %>">Framework</a>
        </nav>
      <% } %>
    <% } %>
  </div>

  <div class="app-sidebar-footer">
    <a href="/" class="app-sidebar-home">Home</a>
  </div>
</aside>
